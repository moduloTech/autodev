#!/usr/bin/env ruby
# frozen_string_literal: true

# =============================================================================
# autodev
#
# Automated implementation of GitLab issues labelled with a trigger label.
# Polls configured projects, clones the repo, implements via danger-claude,
# commits, pushes, manages labels, creates a Merge Request, and optionally
# runs mr-review in headless mode.
#
# Usage:
#   autodev                                  # Poll with default config
#   autodev --once                           # Single poll cycle then exit
#   autodev -c ~/.autodev/custom.yml --once  # Custom config, single cycle
#
# Configuration (priority: defaults < config.yml < env vars < CLI flags):
#   ~/.autodev/config.yml    Central config file
#   GITLAB_API_TOKEN         Personal Access Token with api scope
# =============================================================================

require "bundler/inline"

gemfile(true) do
  source "https://rubygems.org"
  gem "gitlab",  "~> 5.0"
  gem "sequel",  "~> 5.0"
  gem "sqlite3", "~> 2.0"
  gem "pastel",  "~> 0.8"
end

require "fileutils"
require "json"
require "open3"
require "optparse"
require "shellwords"
require "uri"
require "yaml"
require "thread"

# == Exceptions ================================================================

class AutodevError < StandardError; end
class ConfigError < AutodevError; end
class GitError < AutodevError; end
class ImplementationError < AutodevError; end

# Env hash that explicitly unsets all Bundler-related vars in child processes.
# Using nil values tells Process.spawn to delete these vars from the child env,
# preventing bundler/inline contamination when spawning danger-claude or mr-review
# from a directory containing its own Gemfile.
CLEAN_ENV = %w[
  BUNDLE_GEMFILE BUNDLE_PATH BUNDLE_BIN_PATH BUNDLE_APP_CONFIG
  BUNDLE_ORIG_GEMFILE BUNDLER_VERSION BUNDLER_ORIG_BUNDLER_VERSION
  BUNDLER_SETUP RUBYOPT RUBYLIB
].each_with_object({}) { |var, h| h[var] = nil }.freeze

# == Configuration =============================================================

module Config
  CONFIG_DIR  = File.expand_path("~/.autodev")
  CONFIG_PATH = File.join(CONFIG_DIR, "config.yml")
  DEFAULT_DB  = File.join(CONFIG_DIR, "autodev.db")

  TEMPLATE = <<~YAML
    # autodev configuration
    # See: https://github.com/moduloTech/autodev

    gitlab_url: https://gitlab.example.com
    gitlab_token: glpat-xxxxxxxxxxxxxxxxxxxx   # or set GITLAB_API_TOKEN env var
    trigger_label: autodev                      # label that triggers processing
    poll_interval: 300                          # seconds between poll cycles
    max_workers: 3                              # concurrent worker threads
    # database_url: sqlite://~/.autodev/autodev.db  # default

    projects:
      - path: group/project-name
        # target_branch: develop                # optional, defaults to project default branch
        # labels_to_remove:                     # labels to remove after MR creation
        #   - "development::todo"
        #   - "todo"
        # label_to_add: "Development::Awaiting CR"
        # extra_prompt: "Use RSpec for tests"   # additional instructions for Claude
  YAML

  DEFAULTS = {
    "gitlab_url"     => nil,
    "gitlab_token"   => nil,
    "trigger_label"  => "autodev",
    "poll_interval"  => 300,
    "max_workers"    => 3,
    "database_url"   => "sqlite://#{DEFAULT_DB}",
    "projects"       => []
  }.freeze

  ENV_MAPPING = {
    "GITLAB_API_TOKEN" => "gitlab_token",
    "GITLAB_URL"       => "gitlab_url"
  }.freeze

  def self.load(cli_overrides = {})
    config_path = cli_overrides.delete("config_path") || CONFIG_PATH

    config = DEFAULTS.dup

    # Layer 2: config.yml
    if File.exist?(config_path)
      yaml = YAML.safe_load(File.read(config_path), permitted_classes: [Symbol]) || {}
      yaml.each { |k, v| config[k] = v unless v.nil? }
    end

    # Layer 3: environment variables
    ENV_MAPPING.each do |env_key, config_key|
      config[config_key] = ENV[env_key] if ENV.key?(env_key)
    end

    # Layer 4: CLI flags (highest priority)
    cli_overrides.each { |k, v| config[k] = v unless v.nil? }

    # Track which config path was used
    config["_config_path"] = config_path

    # Coerce types
    config["poll_interval"] = config["poll_interval"].to_i
    config["max_workers"]   = config["max_workers"].to_i

    config
  end
end

# == Argument parsing ==========================================================

def parse_args(argv)
  cli_overrides = {}

  parser = OptionParser.new do |opts|
    opts.banner = "Usage: autodev [options]"

    opts.on("-c", "--config PATH", "Config file (default: ~/.autodev/config.yml)") do |v|
      cli_overrides["config_path"] = v
    end

    opts.on("-d", "--database-url URL", "SQLite database URL") do |v|
      cli_overrides["database_url"] = v
    end

    opts.on("-t", "--token TOKEN", "GitLab API token") do |v|
      cli_overrides["gitlab_token"] = v
    end

    opts.on("-n", "--max-workers N", Integer, "Concurrent workers (default: 3)") do |v|
      cli_overrides["max_workers"] = v
    end

    opts.on("-i", "--interval SECONDS", Integer, "Poll interval in seconds") do |v|
      cli_overrides["poll_interval"] = v
    end

    opts.on("--once", "Single poll cycle then exit") do
      cli_overrides["once"] = true
    end

    opts.on("-h", "--help", "Show this help") do
      puts opts
      exit 0
    end
  end

  parser.parse(argv)
  Config.load(cli_overrides)
end

# == Database ==================================================================

module Database
  @db = nil

  def self.connect(url)
    return unless url

    if url.start_with?("sqlite://")
      db_path = url.sub("sqlite://", "")
      # Expand ~ in path
      db_path = File.expand_path(db_path)
      url = "sqlite://#{db_path}"
      FileUtils.mkdir_p(File.dirname(db_path))
    end

    @db = Sequel.connect(url, max_connections: 5)
    @db.run("PRAGMA journal_mode=WAL")
    @db.run("PRAGMA busy_timeout=5000")
    migrate!
    true
  rescue Sequel::DatabaseConnectionError, Sequel::DatabaseError => e
    warn "  Database connection failed: #{e.message}"
    @db = nil
    false
  end

  def self.connected?
    !@db.nil?
  end

  def self.disconnect
    @db&.disconnect
    @db = nil
  end

  def self.db
    @db
  end

  # -- Schema migration --

  def self.migrate!
    @db.run <<~SQL
      CREATE TABLE IF NOT EXISTS issues (
        id            INTEGER PRIMARY KEY AUTOINCREMENT,
        project_path  TEXT NOT NULL,
        issue_iid     INTEGER NOT NULL,
        issue_title   TEXT,
        branch_name   TEXT,
        status        TEXT NOT NULL DEFAULT 'pending',
        mr_iid        INTEGER,
        mr_url        TEXT,
        error_message TEXT,
        started_at    TEXT,
        finished_at   TEXT,
        created_at    TEXT NOT NULL DEFAULT (datetime('now')),
        UNIQUE(project_path, issue_iid)
      );
    SQL
  end

  # -- Issues CRUD --

  def self.find_issue(project_path, issue_iid)
    return nil unless connected?
    @db[:issues].where(project_path: project_path, issue_iid: issue_iid).first
  end

  def self.insert_issue(project_path:, issue_iid:, issue_title:)
    return nil unless connected?
    @db[:issues].insert(
      project_path: project_path,
      issue_iid:    issue_iid,
      issue_title:  issue_title,
      status:       "pending"
    )
  rescue Sequel::UniqueConstraintViolation
    # Already tracked
    nil
  end

  def self.update_issue(project_path, issue_iid, **fields)
    return unless connected?
    @db[:issues].where(project_path: project_path, issue_iid: issue_iid).update(**fields)
  end

  def self.reset_errors_to_pending!
    return unless connected?
    count = @db[:issues].where(status: "error").update(status: "pending", error_message: nil, started_at: nil)
    count
  end
end

# == GitLab helpers ============================================================

def build_gitlab_client(gitlab_url, token)
  raise ConfigError, "Missing GitLab API token (set GITLAB_API_TOKEN, use -t, or add gitlab_token to config)" unless token
  raise ConfigError, "Missing gitlab_url in config" unless gitlab_url

  Gitlab.client(endpoint: "#{gitlab_url}/api/v4", private_token: token)
end

def fetch_trigger_issues(client, project_path, trigger_label)
  client.issues(project_path, labels: trigger_label, state: "opened", per_page: 100)
rescue Gitlab::Error::ResponseError => e
  raise AutodevError, "Failed to fetch issues for #{project_path}: #{e.message}"
end

def fetch_issue_context(client, project_path, issue_iid)
  issue = client.issue(project_path, issue_iid)

  lines = []
  lines << "# Issue ##{issue.iid}: #{issue.title}"
  lines << ""
  lines << issue.description.to_s if issue.description && !issue.description.empty?
  lines << ""

  # Fetch comments/discussions
  begin
    notes = client.issue_notes(project_path, issue_iid, per_page: 100)
    user_notes = notes.select { |n| !n.system }
    if user_notes.any?
      lines << "## Comments"
      lines << ""
      user_notes.each do |note|
        lines << "### #{note.author&.name || "Unknown"} (#{note.created_at})"
        lines << note.body.to_s
        lines << ""
      end
    end
  rescue Gitlab::Error::ResponseError
    # Non-fatal: proceed without comments
  end

  # Fetch linked merge requests / related issues
  begin
    links = client.issue_links(project_path, issue_iid)
    if links.any?
      lines << "## Related issues"
      lines << ""
      links.each do |link|
        lines << "- ##{link.iid}: #{link.title} (#{link.state})"
      end
      lines << ""
    end
  rescue Gitlab::Error::ResponseError, NoMethodError
    # Non-fatal: some GitLab versions don't support this
  end

  lines.join("\n")
end

# == Shell helpers =============================================================

def run_cmd(cmd, chdir: nil, env: {})
  spawn_opts = {}
  spawn_opts[:chdir] = chdir if chdir
  out, err, status = Open3.capture3(env, *cmd, **spawn_opts)
  unless status.success?
    raise GitError, "Command failed: #{cmd.is_a?(Array) ? cmd.join(" ") : cmd}\nstdout: #{out[0, 500]}\nstderr: #{err[0, 500]}"
  end
  out.strip
end

def run_cmd_status(cmd, chdir: nil, env: {})
  spawn_opts = {}
  spawn_opts[:chdir] = chdir if chdir
  out, err, status = Open3.capture3(env, *cmd, **spawn_opts)
  [out.strip, err.strip, status.success?]
end

# == IssueProcessor ===========================================================

class IssueProcessor
  def initialize(client:, config:, project_config:, pastel:, token:)
    @client         = client
    @config         = config
    @project_config = project_config
    @pastel         = pastel
    @token          = token
    @project_path   = project_config["path"]
    @gitlab_url     = config["gitlab_url"]
  end

  def process(issue)
    iid   = issue.iid
    title = issue.title

    log "Processing issue ##{iid}: #{title}"
    Database.update_issue(@project_path, iid, status: "cloning", started_at: Sequel.lit("datetime('now')"))

    # Verify issue is still open
    current = @client.issue(@project_path, iid)
    if current.state != "opened"
      log "Issue ##{iid} is no longer open (#{current.state}), skipping"
      Database.update_issue(@project_path, iid, status: "done", finished_at: Sequel.lit("datetime('now')"))
      return
    end

    work_dir = "/tmp/autodev_#{@project_path.gsub("/", "_")}_#{iid}"
    begin
      # 1. Clone
      clone_repo(work_dir)

      # 2. Branch
      branch_name = create_branch(work_dir, iid, title)
      Database.update_issue(@project_path, iid, branch_name: branch_name, status: "implementing")

      # 3. Fetch full issue context
      context = fetch_issue_context(@client, @project_path, iid)

      # 4. Ensure CLAUDE.md exists
      ensure_claude_md(work_dir)

      # 5. Implement
      implement(work_dir, context, iid)
      Database.update_issue(@project_path, iid, status: "committing")

      # 6. Commit
      commit(work_dir)

      # 7. Verify changes were produced
      verify_changes(work_dir, branch_name)
      Database.update_issue(@project_path, iid, status: "pushing")

      # 8. Push
      push(work_dir, branch_name)

      # 9. Create MR
      Database.update_issue(@project_path, iid, status: "creating_mr")
      mr = create_merge_request(work_dir, iid, branch_name, title)
      Database.update_issue(@project_path, iid, mr_iid: mr.iid, mr_url: mr.web_url, status: "reviewing")

      # 10. Labels (after MR to avoid bad state on failure)
      update_labels(iid)

      # 11. Review (non-fatal)
      run_review(mr.web_url)

      Database.update_issue(@project_path, iid, status: "done", finished_at: Sequel.lit("datetime('now')"))
      log "Issue ##{iid} completed: #{mr.web_url}"

    rescue StandardError => e
      bt = e.backtrace&.first(10)&.join("\n  ")
      Database.update_issue(@project_path, iid,
        status: "error",
        error_message: "#{e.class}: #{e.message}\n  #{bt}",
        finished_at: Sequel.lit("datetime('now')")
      )
      log_error "Issue ##{iid} failed: #{e.class}: #{e.message}"
      log_error "  #{bt}" if bt
    ensure
      # Cleanup temp directory
      FileUtils.rm_rf(work_dir) if work_dir && Dir.exist?(work_dir)
    end
  end

  private

  def clone_repo(work_dir)
    FileUtils.rm_rf(work_dir) if Dir.exist?(work_dir)

    uri = URI.parse(@gitlab_url)
    host_port = uri.port && ![80, 443].include?(uri.port) ? "#{uri.host}:#{uri.port}" : uri.host
    clone_url = "#{uri.scheme}://oauth2:#{@token}@#{host_port}/#{@project_path}.git"

    log "Cloning #{@project_path}..."
    run_cmd(["git", "clone", clone_url, work_dir])
  end

  def create_branch(work_dir, iid, title)
    # Determine base branch
    target = @project_config["target_branch"]
    if target
      run_cmd(["git", "checkout", target], chdir: work_dir)
    end

    slug = title.downcase
                .gsub(/[^a-z0-9\s-]/, "")
                .gsub(/\s+/, "-")
                .gsub(/-+/, "-")
                .gsub(/^-|-$/, "")[0, 50]
    branch_name = "autodev/#{iid}-#{slug}"

    run_cmd(["git", "checkout", "-b", branch_name], chdir: work_dir)
    log "Created branch: #{branch_name}"
    branch_name
  end

  def ensure_claude_md(work_dir)
    claude_md = File.join(work_dir, "CLAUDE.md")
    return if File.exist?(claude_md)

    log "No CLAUDE.md found, generating..."
    danger_claude_prompt(
      work_dir,
      "Analyse ce projet (structure, technologies, conventions, tests) et cree un fichier CLAUDE.md " \
      "a la racine qui documente ces informations pour guider les futurs developpements. " \
      "Sois concis et factuel."
    )
    danger_claude_commit(work_dir)
  end

  def implement(work_dir, context, iid)
    extra = @project_config["extra_prompt"]
    prompt = <<~PROMPT
      Tu dois implementer le ticket GitLab suivant. Lis attentivement le contexte complet ci-dessous,
      puis implemente les changements necessaires dans le code.

      #{context}

      ## Instructions

      - Implemente TOUS les changements decrits dans l'issue.
      - Respecte les conventions du projet (voir CLAUDE.md si present).
      - Ajoute ou modifie les tests si necessaire.
      - Ne modifie que ce qui est necessaire pour resoudre l'issue.
      #{extra ? "\n## Instructions supplementaires du projet\n\n#{extra}" : ""}
    PROMPT

    log "Running implementation via danger-claude..."
    danger_claude_prompt(work_dir, prompt)
  end

  def commit(work_dir)
    log "Committing changes via danger-claude..."
    danger_claude_commit(work_dir)
  end

  def verify_changes(work_dir, branch_name)
    # Check if there are commits beyond the base
    target = @project_config["target_branch"] || default_branch(work_dir)
    out, _err, ok = run_cmd_status(
      ["git", "log", "#{target}..#{branch_name}", "--oneline"],
      chdir: work_dir
    )
    if !ok || out.strip.empty?
      raise ImplementationError, "No changes produced by implementation"
    end
  end

  def default_branch(work_dir)
    # Try to detect default branch from remote
    out, _err, ok = run_cmd_status(["git", "symbolic-ref", "refs/remotes/origin/HEAD", "--short"], chdir: work_dir)
    if ok && !out.empty?
      out.sub("origin/", "")
    else
      "main"
    end
  end

  def push(work_dir, branch_name)
    log "Pushing #{branch_name}..."
    _out, _err, ok = run_cmd_status(
      ["git", "push", "-u", "origin", branch_name],
      chdir: work_dir
    )
    unless ok
      # Retry with force-with-lease
      log "Push failed, retrying with --force-with-lease..."
      run_cmd(["git", "push", "--force-with-lease", "-u", "origin", branch_name], chdir: work_dir)
    end
  end

  def update_labels(iid)
    # Remove configured labels
    labels_to_remove = @project_config["labels_to_remove"] || []
    label_to_add     = @project_config["label_to_add"]

    begin
      issue = @client.issue(@project_path, iid)
      current_labels = issue.labels || []

      new_labels = current_labels - labels_to_remove
      new_labels << label_to_add if label_to_add && !new_labels.include?(label_to_add)

      @client.edit_issue(@project_path, iid, labels: new_labels.join(","))
      log "Labels updated: removed #{labels_to_remove & current_labels}, added #{label_to_add}"
    rescue Gitlab::Error::ResponseError => e
      log_error "Failed to update labels for ##{iid}: #{e.message}"
    end
  end

  def create_merge_request(work_dir, iid, branch_name, issue_title)
    target = @project_config["target_branch"] || default_branch(work_dir)

    # Get commit message for MR description
    commit_msg = run_cmd(["git", "log", "-1", "--format=%B"], chdir: work_dir)
    commit_subject = run_cmd(["git", "log", "-1", "--format=%s"], chdir: work_dir)

    mr_title = commit_subject
    mr_description = "#{commit_msg}\n\nFixes ##{iid}"

    # Check if MR already exists for this branch
    begin
      existing_mrs = @client.merge_requests(@project_path, source_branch: branch_name, state: "opened")
      if existing_mrs.any?
        mr = existing_mrs.first
        log "MR already exists: !#{mr.iid}"
        return mr
      end
    rescue Gitlab::Error::ResponseError
      # Continue to create
    end

    log "Creating MR: #{mr_title}"
    @client.create_merge_request(
      @project_path,
      mr_title,
      source_branch: branch_name,
      target_branch: target,
      description:   mr_description
    )
  end

  def run_review(mr_url)
    unless command_exists?("mr-review")
      log "mr-review not installed, skipping review"
      return
    end

    log "Waiting 15s for GitLab to compute diff_refs..."
    sleep 15
    log "Running mr-review on #{mr_url}..."
    out, err, status = Open3.capture3(CLEAN_ENV, "mr-review", "-H", mr_url)
    if status.success?
      log "Review completed successfully"
    else
      log_error "mr-review failed (non-fatal): #{err[0, 300]}"
    end
  rescue StandardError => e
    log_error "mr-review error (non-fatal): #{e.message}"
  end

  def danger_claude_prompt(work_dir, prompt)
    out, err, status = Open3.capture3(CLEAN_ENV, "danger-claude", "-p", prompt, chdir: work_dir)
    unless status.success?
      raise ImplementationError, "danger-claude -p failed:\nstdout: #{out[0, 500]}\nstderr: #{err[0, 500]}"
    end
    out
  end

  def danger_claude_commit(work_dir)
    out, err, status = Open3.capture3(CLEAN_ENV, "danger-claude", "-c", chdir: work_dir)
    unless status.success?
      raise ImplementationError, "danger-claude -c failed:\nstdout: #{out[0, 500]}\nstderr: #{err[0, 500]}"
    end
    out
  end

  def command_exists?(cmd)
    _, status = Open3.capture2e("which", cmd)
    status.success?
  end

  def log(msg)
    puts "  #{@pastel.cyan("[#{@project_path}]")} #{msg}"
  end

  def log_error(msg)
    warn "  #{@pastel.red("[#{@project_path}]")} #{msg}"
  end
end

# == WorkerPool ================================================================

class WorkerPool
  def initialize(size:, pastel:)
    @size    = size
    @queue   = Queue.new
    @pastel  = pastel
    @threads = []
    @running = true
  end

  def start
    @threads = @size.times.map do |i|
      Thread.new do
        Thread.current.name = "worker-#{i}"
        while @running
          begin
            job = @queue.pop(true)
            job.call
          rescue ThreadError
            # Queue empty, wait briefly
            sleep 0.5
          rescue StandardError => e
            warn @pastel.red("  [worker-#{i}] Unhandled error: #{e.class}: #{e.message}")
          end
        end
      end
    end
  end

  def enqueue(&block)
    @queue.push(block)
  end

  def shutdown(timeout: 30)
    @running = false
    # Push sentinel values to unblock waiting threads
    @size.times { @queue.push(-> {}) }
    @threads.each { |t| t.join(timeout) }
  end

  def busy?
    !@queue.empty?
  end
end

# == Main ======================================================================

def main
  pastel = Pastel.new

  puts pastel.bold.blue("+=== autodev ================================================+")

  # 1. Parse args + load config
  config = parse_args(ARGV)

  # 2. Validate — offer to create template config if missing
  config_path = config["_config_path"] || Config::CONFIG_PATH

  unless File.exist?(config_path)
    puts pastel.yellow("  No config file found at #{config_path}")
    print pastel.bold("  Create a template config to edit? [Y/n] ")
    answer = $stdin.gets&.strip&.downcase
    if answer.nil? || answer.empty? || answer == "y"
      FileUtils.mkdir_p(File.dirname(config_path))
      File.write(config_path, Config::TEMPLATE)
      puts pastel.green("  Created #{config_path}")
      puts "  Edit this file with your GitLab URL, token and projects, then re-run autodev."
      exit 0
    else
      raise ConfigError, "No config file at #{config_path}. Create one manually or re-run to generate a template."
    end
  end

  unless config["projects"].is_a?(Array) && config["projects"].any?
    raise ConfigError, "No projects configured in #{config_path}. Add at least one entry under 'projects:'."
  end

  unless config["gitlab_url"] && config["gitlab_url"] != "https://gitlab.example.com"
    raise ConfigError, "Set a valid gitlab_url in #{config_path}"
  end

  # Check danger-claude is available
  _, dc_status = Open3.capture2e("which", "danger-claude")
  raise ConfigError, "danger-claude is not installed or not on PATH" unless dc_status.success?

  # Check mr-review (warning only)
  _, mr_status = Open3.capture2e("which", "mr-review")
  unless mr_status.success?
    puts pastel.yellow("  Warning: mr-review not installed, review step will be skipped")
  end

  # 3. Connect SQLite + migrate
  token = config["gitlab_token"]
  client = build_gitlab_client(config["gitlab_url"], token)

  if Database.connect(config["database_url"])
    puts pastel.dim("  Database connected")
  else
    raise ConfigError, "Database connection required for autodev"
  end

  # Reset errored issues for retry
  reset_count = Database.reset_errors_to_pending!
  puts pastel.yellow("  Reset #{reset_count} errored issue(s) to pending") if reset_count && reset_count > 0

  # 4. Start WorkerPool
  pool = WorkerPool.new(size: config["max_workers"], pastel: pastel)
  pool.start
  puts pastel.dim("  Worker pool started (#{config["max_workers"]} workers)")

  # 5. Trap signals
  shutdown_requested = false
  %w[INT TERM].each do |sig|
    Signal.trap(sig) do
      shutdown_requested = true
    end
  end

  trigger_label = config["trigger_label"]

  # 6. Poll loop
  loop do
    break if shutdown_requested

    config["projects"].each do |project_config|
      break if shutdown_requested

      project_path = project_config["path"]
      puts pastel.dim("  Polling #{project_path} for label '#{trigger_label}'...")

      begin
        issues = fetch_trigger_issues(client, project_path, trigger_label)

        issues.each do |issue|
          break if shutdown_requested

          # Skip if already tracked (unless it was reset to pending)
          existing = Database.find_issue(project_path, issue.iid)
          if existing && existing[:status] != "pending"
            next
          end

          # Insert if new
          unless existing
            Database.insert_issue(
              project_path: project_path,
              issue_iid:    issue.iid,
              issue_title:  issue.title
            )
          end

          # Build a per-worker client (thread safety)
          worker_client = build_gitlab_client(config["gitlab_url"], token)

          processor = IssueProcessor.new(
            client:         worker_client,
            config:         config,
            project_config: project_config,
            pastel:         pastel,
            token:          token
          )

          pool.enqueue { processor.process(issue) }
          puts "  Enqueued issue ##{issue.iid}: #{issue.title}"
        end
      rescue AutodevError => e
        warn pastel.red("  Error polling #{project_path}: #{e.message}")
      end
    end

    break if config["once"]

    # Sleep in 1s increments for reactive shutdown
    config["poll_interval"].times do
      break if shutdown_requested
      sleep 1
    end
  end

  # 7. Graceful shutdown
  puts pastel.dim("\n  Shutting down workers...")
  pool.shutdown
  puts pastel.bold.green("  autodev stopped.")

rescue ConfigError => e
  pastel ||= Pastel.new
  warn pastel.red.bold("\n  Config error: #{e.message}")
  exit 1

rescue Interrupt
  pastel ||= Pastel.new
  warn pastel.yellow("\n  Interrupted.")
  exit 130

rescue StandardError => e
  pastel ||= Pastel.new
  warn pastel.red.bold("\n  Unexpected error: #{e.class}: #{e.message}")
  warn pastel.dim(e.backtrace&.first(5)&.join("\n  "))
  exit 1

ensure
  Database.disconnect
end

main
