#!/usr/bin/env ruby
# frozen_string_literal: true

# =============================================================================
# autodev
#
# Automated implementation of GitLab issues labelled with a trigger label.
# Polls configured projects, clones the repo, implements via danger-claude,
# commits, pushes, manages labels, creates a Merge Request, and optionally
# runs mr-review in headless mode.
#
# Usage:
#   autodev                                  # Poll with default config
#   autodev --once                           # Single poll cycle then exit
#   autodev --status                         # Show dashboard of tracked issues
#   autodev -c ~/.autodev/custom.yml --once  # Custom config, single cycle
#
# Configuration (priority: defaults < config.yml < env vars < CLI flags):
#   ~/.autodev/config.yml    Central config file
#   GITLAB_API_TOKEN         Personal Access Token with api scope
# =============================================================================

require "bundler/inline"

gemfile(true) do
  source "https://rubygems.org"
  gem "gitlab",  "~> 5.0"
  gem "sequel",  "~> 5.0"
  gem "sqlite3", "~> 2.0"
  gem "pastel",  "~> 0.8"
  gem "i18n",    "~> 1.0"
  gem "aasm",    "~> 5.5"
  gem "logger"
end

require "fileutils"
require "json"
require "open3"
require "optparse"
require "shellwords"
require "net/http"
require "uri"
require "yaml"
require "thread"
require "i18n"
require "securerandom"

# Configure I18n transliteration (no locale files needed, just the transliterator)
I18n.available_locales = [:en]
I18n.default_locale = :en

require_relative "../lib/autodev"

# == Argument parsing ==========================================================

def parse_args(argv)
  cli_overrides = {}

  parser = OptionParser.new do |opts|
    opts.banner = "Usage: autodev [options]"

    opts.on("-c", "--config PATH", "Config file (default: ~/.autodev/config.yml)") do |v|
      cli_overrides["config_path"] = v
    end

    opts.on("-d", "--database-url URL", "SQLite database URL") do |v|
      cli_overrides["database_url"] = v
    end

    opts.on("-t", "--token TOKEN", "GitLab API token") do |v|
      cli_overrides["gitlab_token"] = v
    end

    opts.on("-n", "--max-workers N", Integer, "Concurrent workers (default: 3)") do |v|
      cli_overrides["max_workers"] = v
    end

    opts.on("-i", "--interval SECONDS", Integer, "Poll interval in seconds") do |v|
      cli_overrides["poll_interval"] = v
    end

    opts.on("--once", "Single poll cycle then exit") do
      cli_overrides["once"] = true
    end

    opts.on("--dry-run", "Poll and show what would be processed, no side effects") do
      cli_overrides["dry_run"] = true
      cli_overrides["once"] = true
    end

    opts.on("--status", "Show dashboard of all tracked issues and exit") do
      cli_overrides["status"] = true
    end

    opts.on("-h", "--help", "Show this help") do
      puts opts
      exit 0
    end
  end

  parser.parse(argv)
  Config.load(cli_overrides)
end

# == Dashboard =================================================================

STATUS_COLORS = {
  "pending"              => :yellow,
  "cloning"              => :cyan,
  "checking_spec"        => :cyan,
  "implementing"         => :cyan,
  "committing"           => :cyan,
  "pushing"              => :cyan,
  "creating_mr"          => :cyan,
  "reviewing"            => :cyan,
  "checking_pipeline"    => :cyan,
  "fixing_discussions"   => :magenta,
  "fixing_pipeline"      => :magenta,
  "needs_clarification"  => :yellow,
  "over"                 => :green,
  "blocked"              => :red,
  "error"                => :red,
}.freeze

ACTIVE_STATES = %w[
  cloning checking_spec implementing committing pushing
  creating_mr reviewing checking_pipeline
  fixing_discussions fixing_pipeline
].freeze

def status_label(status)
  case status
  when *ACTIVE_STATES then "En cours"
  when "pending"              then "En attente"
  when "needs_clarification"  then "En attente de clarification"
  when "over"                 then "Terminée"
  when "blocked"              then "Bloquée"
  when "error"                then "Erreur"
  else status
  end
end

def show_dashboard(config)
  pastel = Pastel.new

  Database.connect(config["database_url"])
  Database.build_model!

  issues = Database.db[:issues].order(Sequel.desc(:id)).all

  if issues.empty?
    puts "Aucune issue suivie."
    return
  end

  # Build rows
  rows = issues.map do |row|
    project_short = row[:project_path].to_s.split("/").last
    title = row[:issue_title].to_s
    title = "#{title[0, 37]}…" if title.length > 38
    status = row[:status]
    label = status_label(status)
    comment = label.dup
    comment << " (#{status})" if ACTIVE_STATES.include?(status)
    if row[:mr_url]
      comment << " — MR !#{row[:mr_iid]}"
    end
    if status == "error" && row[:error_message]
      err = row[:error_message].to_s.lines.first.to_s.strip
      err = "#{err[0, 40]}…" if err.length > 41
      comment << " — #{err}"
    end
    if status == "needs_clarification"
      comment << " depuis #{row[:clarification_requested_at]}" if row[:clarification_requested_at]
    end

    {
      iid: "##{row[:issue_iid]}",
      title: "#{title} (#{project_short})",
      status: status,
      comment: comment,
    }
  end

  # Column widths
  w_iid     = [rows.map { |r| r[:iid].length }.max, 5].max
  w_title   = [rows.map { |r| r[:title].length }.max, 5].max
  w_status  = [rows.map { |r| r[:status].length }.max, 8].max
  w_comment = [rows.map { |r| r[:comment].length }.max, 12].max

  sep  = "+-#{"-" * w_iid}-+-#{"-" * w_title}-+-#{"-" * w_status}-+-#{"-" * w_comment}-+"
  head = "| #{"#".ljust(w_iid)} | #{"Issue".ljust(w_title)} | #{"État".ljust(w_status)} | #{"Commentaire".ljust(w_comment)} |"

  puts sep
  puts pastel.bold(head)
  puts sep

  rows.each do |row|
    color = STATUS_COLORS[row[:status]] || :white
    colored_status = pastel.send(color, row[:status].ljust(w_status))
    line = "| #{row[:iid].ljust(w_iid)} | #{row[:title].ljust(w_title)} | #{colored_status} | #{row[:comment].ljust(w_comment)} |"
    puts line
  end

  puts sep

  # Summary
  active  = rows.count { |r| ACTIVE_STATES.include?(r[:status]) || r[:status] == "pending" }
  done    = rows.count { |r| r[:status] == "over" }
  blocked = rows.count { |r| %w[blocked error needs_clarification].include?(r[:status]) }
  puts "#{pastel.bold(rows.size.to_s)} issues — #{pastel.cyan("#{active} actives")}, #{pastel.green("#{done} terminées")}, #{pastel.yellow("#{blocked} bloquées")}"
end

# == Main ======================================================================

def main
  pastel = Pastel.new
  logger = AppLogger.new(pastel: pastel)

  # 1. Parse args + load config
  config = parse_args(ARGV)

  # Handle --status early (only needs DB, not GitLab or danger-claude)
  if config["status"]
    show_dashboard(config)
    exit 0
  end

  logger.info("+=== autodev ================================================+")

  # 2. Configure logger
  logger.configure(log_dir: config["log_dir"], level: config["log_level"])

  # 3. Validate — offer to create template config if missing
  config_path = config["_config_path"] || Config::CONFIG_PATH

  unless File.exist?(config_path)
    logger.warn("No config file found at #{config_path}")
    print pastel.bold("  Create a template config to edit? [Y/n] ")
    answer = $stdin.gets&.strip&.downcase
    if answer.nil? || answer.empty? || answer == "y"
      FileUtils.mkdir_p(File.dirname(config_path))
      File.write(config_path, Config::TEMPLATE)
      logger.info("Created #{config_path}")
      logger.info("Edit this file with your GitLab URL, token and projects, then re-run autodev.")
      exit 0
    else
      raise ConfigError, "No config file at #{config_path}. Create one manually or re-run to generate a template."
    end
  end

  unless config["projects"].is_a?(Array) && config["projects"].any?
    raise ConfigError, "No projects configured in #{config_path}. Add at least one entry under 'projects:'."
  end

  unless config["gitlab_url"] && config["gitlab_url"] != "https://gitlab.example.com"
    raise ConfigError, "Set a valid gitlab_url in #{config_path}"
  end

  # Check danger-claude is available
  _, dc_status = Open3.capture2e("which", "danger-claude")
  raise ConfigError, "danger-claude is not installed or not on PATH" unless dc_status.success?

  # Check mr-review (warning only)
  _, mr_status = Open3.capture2e("which", "mr-review")
  unless mr_status.success?
    logger.warn("mr-review not installed, review step will be skipped")
  end

  # 4. Connect SQLite + migrate + build model
  token = config["gitlab_token"]
  client = GitlabHelpers.build_gitlab_client(config["gitlab_url"], token)

  if Database.connect(config["database_url"])
    Database.build_model!
    logger.debug("Database connected, Issue model initialized")
  else
    raise ConfigError, "Database connection required for autodev"
  end

  # Recover from previous run
  reset_count = Database.recover_on_startup!(max_retries: config["max_retries"])
  logger.warn("Recovered #{reset_count} issue(s) on startup") if reset_count > 0

  # 5. Start WorkerPool
  pool = WorkerPool.new(size: config["max_workers"], logger: logger)
  pool.start
  logger.debug("Worker pool started (#{config["max_workers"]} workers)")

  # 6. Trap signals
  shutdown_requested = false
  %w[INT TERM].each do |sig|
    Signal.trap(sig) do
      shutdown_requested = true
    end
  end

  trigger_label = config["trigger_label"]

  # 7. Poll loop
  loop do
    break if shutdown_requested

    config["projects"].each do |project_config|
      break if shutdown_requested

      project_path = project_config["path"]
      logger.debug("Polling #{project_path} for label '#{trigger_label}'...", project: project_path)

      # -- New/pending issues --
      begin
        issues = GitlabHelpers.fetch_trigger_issues(client, project_path, trigger_label)

        issues.each do |gl_issue|
          break if shutdown_requested

          existing = Issue.where(project_path: project_path, issue_iid: gl_issue.iid).first
          if existing
            if existing.status == "needs_clarification"
              if GitlabHelpers.clarification_answered?(client, project_path, gl_issue.iid, existing.clarification_requested_at)
                logger.info("Issue ##{gl_issue.iid}: clarification received, re-queuing", project: project_path)
                existing.clarification_received!
                existing.update(clarification_requested_at: nil, error_message: nil)
              else
                next
              end
            elsif existing.status != "pending"
              next
            end
          end

          max_retries = (project_config["max_retries"] || config["max_retries"]).to_i
          if existing && existing.retry_count >= max_retries
            logger.debug("Issue ##{gl_issue.iid} exceeded max retries (#{max_retries}), skipping", project: project_path)
            next
          end

          if config["dry_run"]
            logger.info("[dry-run] Would process issue ##{gl_issue.iid}: #{gl_issue.title}", project: project_path)
            next
          end

          unless existing
            begin
              Issue.create(project_path: project_path, issue_iid: gl_issue.iid,
                           issue_title: gl_issue.title, status: "pending")
            rescue Sequel::UniqueConstraintViolation
              # Already tracked
            end
            existing = Issue.where(project_path: project_path, issue_iid: gl_issue.iid).first
          end

          next unless existing

          worker_client = GitlabHelpers.build_gitlab_client(config["gitlab_url"], token)
          processor = IssueProcessor.new(
            client: worker_client, config: config, project_config: project_config,
            logger: logger, token: token
          )

          pool.enqueue { processor.process(existing) }
          logger.info("Enqueued issue ##{gl_issue.iid}: #{gl_issue.title}", project: project_path)
        end
      rescue AutodevError => e
        logger.error("Error polling #{project_path}: #{e.message}", project: project_path)
      end

      next if config["dry_run"]

      # -- Pipeline monitoring (checking_pipeline) --
      begin
        Issue.where(project_path: project_path, status: "checking_pipeline")
             .exclude(mr_iid: nil).each do |issue|
          break if shutdown_requested

          worker_client = GitlabHelpers.build_gitlab_client(config["gitlab_url"], token)
          monitor = PipelineMonitor.new(
            client: worker_client, config: config, project_config: project_config,
            logger: logger, token: token
          )

          pool.enqueue { monitor.check(issue) }
          logger.info("Enqueued pipeline check for issue ##{issue.issue_iid} (MR !#{issue.mr_iid})", project: project_path)
        end
      rescue StandardError => e
        logger.error("Error polling pipeline monitoring for #{project_path}: #{e.message}", project: project_path)
      end

      # -- Discussion fixes (fixing_discussions) --
      begin
        max_fix_rounds = (project_config["max_fix_rounds"] || config["max_fix_rounds"]).to_i
        Issue.where(project_path: project_path, status: "fixing_discussions")
             .where { fix_round < max_fix_rounds }
             .exclude(mr_iid: nil).each do |issue|
          break if shutdown_requested

          worker_client = GitlabHelpers.build_gitlab_client(config["gitlab_url"], token)
          fixer = MrFixer.new(
            client: worker_client, config: config, project_config: project_config,
            logger: logger, token: token
          )

          pool.enqueue { fixer.fix(issue) }
          logger.info("Enqueued discussion fix for issue ##{issue.issue_iid} (round #{issue.fix_round + 1})", project: project_path)
        end
      rescue StandardError => e
        logger.error("Error polling discussion fixes for #{project_path}: #{e.message}", project: project_path)
      end

      # -- Error retry --
      begin
        max_retries = (project_config["max_retries"] || config["max_retries"]).to_i
        Issue.where(project_path: project_path, status: "error")
             .where { retry_count < max_retries }
             .where { Sequel.lit("next_retry_at IS NOT NULL AND next_retry_at <= datetime('now')") }
             .each do |issue|
          begin
            issue.retry_processing!
            issue.update(error_message: nil, started_at: nil)
            logger.info("Issue ##{issue.issue_iid} retried (attempt #{issue.retry_count + 1})", project: project_path)
          rescue AASM::InvalidTransition => e
            logger.error("Could not retry issue ##{issue.issue_iid}: #{e.message}", project: project_path)
          end
        end
      rescue StandardError => e
        logger.error("Error retrying issues for #{project_path}: #{e.message}", project: project_path)
      end
    end

    break if config["once"]

    config["poll_interval"].times do
      break if shutdown_requested
      sleep 1
    end
  end

  # 8. Graceful shutdown
  logger.info("Shutting down workers...")
  pool.shutdown
  logger.info("autodev stopped.")

rescue ConfigError => e
  logger&.error("Config error: #{e.message}") || (warn "Config error: #{e.message}")
  exit 1

rescue Interrupt
  logger&.warn("Interrupted.") || (warn "Interrupted.")
  exit 130

rescue StandardError => e
  logger&.error("Unexpected error: #{e.class}: #{e.message}") || (warn "Unexpected error: #{e.class}: #{e.message}")
  logger&.error(e.backtrace&.first(5)&.join("\n  ")) if e.backtrace
  exit 1

ensure
  logger&.close
  Database.disconnect
end

main
