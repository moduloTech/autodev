#!/usr/bin/env ruby
# frozen_string_literal: true

# =============================================================================
# autodev
#
# Automated implementation of GitLab issues labelled with a trigger label.
# Polls configured projects, clones the repo, implements via danger-claude,
# commits, pushes, manages labels, creates a Merge Request, and optionally
# runs mr-review in headless mode.
#
# Usage:
#   autodev                                  # Poll with default config
#   autodev --once                           # Single poll cycle then exit
#   autodev -c ~/.autodev/custom.yml --once  # Custom config, single cycle
#
# Configuration (priority: defaults < config.yml < env vars < CLI flags):
#   ~/.autodev/config.yml    Central config file
#   GITLAB_API_TOKEN         Personal Access Token with api scope
# =============================================================================

require "bundler/inline"

gemfile(true) do
  source "https://rubygems.org"
  gem "gitlab",  "~> 5.0"
  gem "sequel",  "~> 5.0"
  gem "sqlite3", "~> 2.0"
  gem "pastel",  "~> 0.8"
  gem "i18n",    "~> 1.0"
end

require "fileutils"
require "json"
require "open3"
require "optparse"
require "shellwords"
require "net/http"
require "uri"
require "yaml"
require "thread"
require "i18n"
require "securerandom"

# Configure I18n transliteration (no locale files needed, just the transliterator)
I18n.available_locales = [:en]
I18n.default_locale = :en

# == Exceptions ================================================================

class AutodevError < StandardError; end
class ConfigError < AutodevError; end
class GitError < AutodevError; end
class ImplementationError < AutodevError; end

# Env hash that explicitly unsets all Bundler-related vars in child processes.
# Using nil values tells Process.spawn to delete these vars from the child env,
# preventing bundler/inline contamination when spawning danger-claude or mr-review
# from a directory containing its own Gemfile.
CLEAN_ENV = %w[
  BUNDLE_GEMFILE BUNDLE_PATH BUNDLE_BIN_PATH BUNDLE_APP_CONFIG
  BUNDLE_ORIG_GEMFILE BUNDLER_VERSION BUNDLER_ORIG_BUNDLER_VERSION
  BUNDLER_SETUP RUBYOPT RUBYLIB
].each_with_object({}) { |var, h| h[var] = nil }.freeze

# == Logging ==================================================================

class AppLogger
  LEVELS = { "DEBUG" => 0, "INFO" => 1, "WARN" => 2, "ERROR" => 3 }.freeze

  def initialize(pastel:)
    @pastel       = pastel
    @mutex        = Mutex.new
    @log_dir      = nil
    @project_dirs = {}
    @global_file  = nil
    @global_date  = nil
    @level        = LEVELS["INFO"]
  end

  def configure(log_dir:, level: "INFO")
    @log_dir = File.expand_path(log_dir)
    @level   = LEVELS[level.to_s.upcase] || LEVELS["INFO"]
    FileUtils.mkdir_p(File.join(@log_dir, "autodev"))
  end

  def debug(msg, project: nil) = write("DEBUG", msg, project: project)
  def info(msg, project: nil)  = write("INFO",  msg, project: project)
  def warn(msg, project: nil)  = write("WARN",  msg, project: project)
  def error(msg, project: nil) = write("ERROR", msg, project: project)

  def close
    @mutex.synchronize do
      @global_file&.close
      @project_dirs.each_value { |f| f[:file]&.close }
    end
  end

  private

  def write(level, msg, project: nil)
    return if LEVELS[level] < @level

    timestamp = Time.now.strftime("%Y-%m-%d %H:%M:%S")
    prefix = project ? "[#{project}]" : "[autodev]"
    line = "#{timestamp} #{level.ljust(5)} #{prefix} #{msg}"

    @mutex.synchronize do
      # Console output with color
      console_line = case level
                     when "ERROR" then @pastel.red("  #{prefix} #{msg}")
                     when "WARN"  then @pastel.yellow("  #{prefix} #{msg}")
                     when "DEBUG" then @pastel.dim("  #{prefix} #{msg}")
                     else "  #{@pastel.cyan(prefix)} #{msg}"
                     end
      if level == "ERROR"
        $stderr.puts console_line
      else
        $stdout.puts console_line
      end

      # File output (if configured)
      write_to_global_file(line) if @log_dir
      write_to_project_file(project, line) if @log_dir && project
    end
  end

  def write_to_global_file(line)
    today = Time.now.strftime("%Y-%m-%d")
    if @global_date != today
      @global_file&.close
      path = File.join(@log_dir, "autodev", "#{today}.log")
      @global_file = File.open(path, "a")
      @global_file.sync = true
      @global_date = today
    end
    @global_file.puts(line)
  end

  def write_to_project_file(project, line)
    slug = project.gsub("/", "_")
    today = Time.now.strftime("%Y-%m-%d")
    entry = @project_dirs[slug] ||= { file: nil, date: nil }

    if entry[:date] != today
      entry[:file]&.close
      dir = File.join(@log_dir, slug)
      FileUtils.mkdir_p(dir)
      path = File.join(dir, "#{today}.log")
      entry[:file] = File.open(path, "a")
      entry[:file].sync = true
      entry[:date] = today
    end
    entry[:file].puts(line)
  end
end

# == Configuration =============================================================

module Config
  CONFIG_DIR  = File.expand_path("~/.autodev")
  CONFIG_PATH = File.join(CONFIG_DIR, "config.yml")
  DEFAULT_DB  = File.join(CONFIG_DIR, "autodev.db")

  TEMPLATE = <<~YAML
    # autodev configuration
    # See: https://github.com/moduloTech/autodev

    gitlab_url: https://gitlab.example.com
    gitlab_token: glpat-xxxxxxxxxxxxxxxxxxxx   # or set GITLAB_API_TOKEN env var
    trigger_label: autodev                      # label that triggers processing
    poll_interval: 300                          # seconds between poll cycles
    max_workers: 3                              # concurrent worker threads
    dc_timeout: 1800                              # danger-claude timeout in seconds (default: 1800 = 30min)
    max_retries: 3                                 # max retry attempts per issue (default: 3)
    retry_backoff: 30                              # base backoff in seconds, doubles each retry (default: 30)
    max_fix_rounds: 3                              # max MR comment fix rounds per issue (default: 3)
    log_dir: ~/.autodev/logs                       # log directory (default: ~/.autodev/logs)
    log_level: INFO                                # DEBUG, INFO, WARN, ERROR (default: INFO)
    # database_url: sqlite://~/.autodev/autodev.db  # default

    projects:
      - path: group/project-name
        # target_branch: develop                # optional, defaults to project default branch
        # labels_to_remove:                     # labels to remove after MR creation
        #   - "development::todo"
        #   - "todo"
        # label_to_add: "Development::Awaiting CR"
        # extra_prompt: "Use RSpec for tests"   # additional instructions for Claude
        # dc_timeout: 1800                        # danger-claude timeout in seconds (overrides global)
        # max_retries: 3                          # max retries per issue (overrides global)
        # retry_backoff: 30                       # base backoff seconds (overrides global)
        # max_fix_rounds: 3                       # max MR comment fix rounds (overrides global)
        # clone_depth: 1                         # git clone depth (0 = full clone, default: 1)
        # sparse_checkout:                       # sparse checkout paths (for monorepos)
        #   - "src/"
        #   - "lib/"
  YAML

  DEFAULTS = {
    "gitlab_url"     => nil,
    "gitlab_token"   => nil,
    "trigger_label"  => "autodev",
    "poll_interval"  => 300,
    "max_workers"    => 3,
    "dc_timeout"     => 1800,
    "max_retries"    => 3,
    "retry_backoff"  => 30,
    "max_fix_rounds" => 3,
    "log_dir"        => File.join(CONFIG_DIR, "logs"),
    "log_level"      => "INFO",
    "database_url"   => "sqlite://#{DEFAULT_DB}",
    "projects"       => []
  }.freeze

  ENV_MAPPING = {
    "GITLAB_API_TOKEN" => "gitlab_token",
    "GITLAB_URL"       => "gitlab_url"
  }.freeze

  def self.load(cli_overrides = {})
    config_path = cli_overrides.delete("config_path") || CONFIG_PATH

    config = DEFAULTS.dup

    # Layer 2: config.yml
    if File.exist?(config_path)
      yaml = YAML.safe_load(File.read(config_path), permitted_classes: [Symbol]) || {}
      yaml.each { |k, v| config[k] = v unless v.nil? }
    end

    # Layer 3: environment variables
    ENV_MAPPING.each do |env_key, config_key|
      config[config_key] = ENV[env_key] if ENV.key?(env_key)
    end

    # Layer 4: CLI flags (highest priority)
    cli_overrides.each { |k, v| config[k] = v unless v.nil? }

    # Track which config path was used
    config["_config_path"] = config_path

    # Coerce types
    config["poll_interval"] = config["poll_interval"].to_i
    config["max_workers"]   = config["max_workers"].to_i
    config["dc_timeout"]    = config["dc_timeout"].to_i
    config["max_retries"]    = config["max_retries"].to_i
    config["retry_backoff"]  = config["retry_backoff"].to_i
    config["max_fix_rounds"] = config["max_fix_rounds"].to_i

    config
  end
end

# == Argument parsing ==========================================================

def parse_args(argv)
  cli_overrides = {}

  parser = OptionParser.new do |opts|
    opts.banner = "Usage: autodev [options]"

    opts.on("-c", "--config PATH", "Config file (default: ~/.autodev/config.yml)") do |v|
      cli_overrides["config_path"] = v
    end

    opts.on("-d", "--database-url URL", "SQLite database URL") do |v|
      cli_overrides["database_url"] = v
    end

    opts.on("-t", "--token TOKEN", "GitLab API token") do |v|
      cli_overrides["gitlab_token"] = v
    end

    opts.on("-n", "--max-workers N", Integer, "Concurrent workers (default: 3)") do |v|
      cli_overrides["max_workers"] = v
    end

    opts.on("-i", "--interval SECONDS", Integer, "Poll interval in seconds") do |v|
      cli_overrides["poll_interval"] = v
    end

    opts.on("--once", "Single poll cycle then exit") do
      cli_overrides["once"] = true
    end

    opts.on("--dry-run", "Poll and show what would be processed, no side effects") do
      cli_overrides["dry_run"] = true
      cli_overrides["once"] = true
    end

    opts.on("-h", "--help", "Show this help") do
      puts opts
      exit 0
    end
  end

  parser.parse(argv)
  Config.load(cli_overrides)
end

# == Database ==================================================================

module Database
  @db = nil

  def self.connect(url)
    return unless url

    if url.start_with?("sqlite://")
      db_path = url.sub("sqlite://", "")
      # Expand ~ in path
      db_path = File.expand_path(db_path)
      url = "sqlite://#{db_path}"
      FileUtils.mkdir_p(File.dirname(db_path))
    end

    @db = Sequel.connect(url, max_connections: 5)
    @db.run("PRAGMA journal_mode=WAL")
    @db.run("PRAGMA busy_timeout=5000")
    migrate!
    true
  rescue Sequel::DatabaseConnectionError, Sequel::DatabaseError => e
    warn "  Database connection failed: #{e.message}"
    @db = nil
    false
  end

  def self.connected?
    !@db.nil?
  end

  def self.disconnect
    @db&.disconnect
    @db = nil
  end

  def self.db
    @db
  end

  # -- Schema migration --

  def self.migrate!
    @db.run <<~SQL
      CREATE TABLE IF NOT EXISTS issues (
        id            INTEGER PRIMARY KEY AUTOINCREMENT,
        project_path  TEXT NOT NULL,
        issue_iid     INTEGER NOT NULL,
        issue_title   TEXT,
        branch_name   TEXT,
        status        TEXT NOT NULL DEFAULT 'pending',
        mr_iid        INTEGER,
        mr_url        TEXT,
        error_message TEXT,
        dc_stdout      TEXT,
        dc_stderr      TEXT,
        retry_count    INTEGER NOT NULL DEFAULT 0,
        fix_round      INTEGER NOT NULL DEFAULT 0,
        next_retry_at  TEXT,
        clarification_requested_at TEXT,
        started_at     TEXT,
        finished_at    TEXT,
        created_at     TEXT NOT NULL DEFAULT (datetime('now')),
        UNIQUE(project_path, issue_iid)
      );
    SQL

    # Add columns for existing databases
    %w[dc_stdout dc_stderr].each do |col|
      @db.run("ALTER TABLE issues ADD COLUMN #{col} TEXT") rescue nil
    end
    @db.run("ALTER TABLE issues ADD COLUMN retry_count INTEGER NOT NULL DEFAULT 0") rescue nil
    @db.run("ALTER TABLE issues ADD COLUMN next_retry_at TEXT") rescue nil
    @db.run("ALTER TABLE issues ADD COLUMN clarification_requested_at TEXT") rescue nil
    @db.run("ALTER TABLE issues ADD COLUMN fix_round INTEGER NOT NULL DEFAULT 0") rescue nil
    @db.run("ALTER TABLE issues ADD COLUMN pipeline_retrigger_count INTEGER NOT NULL DEFAULT 0") rescue nil
  end

  # -- Issues CRUD --

  def self.find_issue(project_path, issue_iid)
    return nil unless connected?
    @db[:issues].where(project_path: project_path, issue_iid: issue_iid).first
  end

  def self.insert_issue(project_path:, issue_iid:, issue_title:)
    return nil unless connected?
    @db[:issues].insert(
      project_path: project_path,
      issue_iid:    issue_iid,
      issue_title:  issue_title,
      status:       "pending"
    )
  rescue Sequel::UniqueConstraintViolation
    # Already tracked
    nil
  end

  def self.update_issue(project_path, issue_iid, **fields)
    return unless connected?
    @db[:issues].where(project_path: project_path, issue_iid: issue_iid).update(**fields)
  end

  def self.reset_errors_to_pending!(max_retries:)
    return unless connected?
    # Only reset errors that haven't exceeded max retries
    count = @db[:issues]
      .where(status: "error")
      .where { retry_count < max_retries }
      .where { Sequel.lit("next_retry_at IS NULL OR next_retry_at <= datetime('now')") }
      .update(status: "pending", error_message: nil, started_at: nil)
    # Reset interrupted pipeline fixes back to mr_pipeline_running
    count2 = @db[:issues]
      .where(status: "mr_pipeline_fixing")
      .update(status: "mr_pipeline_running")
    (count || 0) + (count2 || 0)
  end

  def self.exceeded_max_retries?(project_path, issue_iid, max_retries)
    return false unless connected?
    row = find_issue(project_path, issue_iid)
    row && row[:retry_count] >= max_retries
  end

  def self.issues_for_mr_fixing(project_path, max_fix_rounds)
    return [] unless connected?
    @db[:issues]
      .where(project_path: project_path)
      .where(status: "mr_fixing")
      .where { fix_round < max_fix_rounds }
      .exclude(mr_iid: nil)
      .all
  end

  def self.transition_to_pipeline_running!(project_path, max_fix_rounds)
    return unless connected?
    # Mark max-rounds mr_fixed as over (terminal — we gave up fixing)
    @db[:issues]
      .where(project_path: project_path)
      .where(status: "mr_fixed")
      .where { fix_round >= max_fix_rounds }
      .update(status: "over")
    # Transition done and mr_fixed → mr_pipeline_running
    @db[:issues]
      .where(project_path: project_path)
      .where(status: %w[done mr_fixed])
      .exclude(mr_iid: nil)
      .update(status: "mr_pipeline_running", pipeline_retrigger_count: 0)
  end

  def self.issues_for_pipeline_monitoring(project_path)
    return [] unless connected?
    @db[:issues]
      .where(project_path: project_path, status: "mr_pipeline_running")
      .exclude(mr_iid: nil)
      .all
  end
end

# == GitLab helpers ============================================================

def build_gitlab_client(gitlab_url, token)
  raise ConfigError, "Missing GitLab API token (set GITLAB_API_TOKEN, use -t, or add gitlab_token to config)" unless token
  raise ConfigError, "Missing gitlab_url in config" unless gitlab_url

  Gitlab.client(endpoint: "#{gitlab_url}/api/v4", private_token: token)
end

def fetch_trigger_issues(client, project_path, trigger_label)
  client.issues(project_path, labels: trigger_label, state: "opened", per_page: 100)
rescue Gitlab::Error::ResponseError => e
  raise AutodevError, "Failed to fetch issues for #{project_path}: #{e.message}"
end

def download_gitlab_images(text, gitlab_url:, project_path:, token:, dest_dir:)
  image_dir = File.join(dest_dir, ".autodev-images")
  downloaded = false

  result = text.gsub(/!\[([^\]]*)\]\((\/uploads\/[^)]+)\)(\{[^}]*\})?/) do
    alt = $1
    upload_path = $2
    url = "#{gitlab_url}/#{project_path}#{upload_path}"
    filename = File.basename(upload_path)
    local_path = File.join(image_dir, filename)

    begin
      unless downloaded
        FileUtils.mkdir_p(image_dir)
        downloaded = true
      end

      uri = URI.parse(url)
      http = Net::HTTP.new(uri.host, uri.port)
      http.use_ssl = (uri.scheme == "https")
      request = Net::HTTP::Get.new(uri.request_uri)
      request["PRIVATE-TOKEN"] = token
      response = http.request(request)

      if response.is_a?(Net::HTTPSuccess)
        File.binwrite(local_path, response.body)
        "![#{alt}](#{local_path})"
      else
        "[Image: #{filename} — download failed (#{response.code})]"
      end
    rescue StandardError
      "[Image: #{filename} — download failed]"
    end
  end

  result
end

def fetch_issue_context(client, project_path, issue_iid, gitlab_url: nil, token: nil, work_dir: nil)
  issue = client.issue(project_path, issue_iid)
  can_download = gitlab_url && token && work_dir

  lines = []
  lines << "# Issue ##{issue.iid}: #{issue.title}"
  lines << ""
  if issue.description && !issue.description.empty?
    desc = issue.description.to_s
    desc = download_gitlab_images(desc, gitlab_url: gitlab_url, project_path: project_path, token: token, dest_dir: work_dir) if can_download
    lines << desc
  end
  lines << ""

  # Fetch comments/discussions
  begin
    notes = client.issue_notes(project_path, issue_iid, per_page: 100)
    user_notes = notes.select { |n| !n.system && !n.body.to_s.include?("**autodev**") }
    if user_notes.any?
      lines << "## Comments"
      lines << ""
      user_notes.each do |note|
        lines << "### #{note.author&.name || "Unknown"} (#{note.created_at})"
        body = note.body.to_s
        body = download_gitlab_images(body, gitlab_url: gitlab_url, project_path: project_path, token: token, dest_dir: work_dir) if can_download
        lines << body
        lines << ""
      end
    end
  rescue Gitlab::Error::ResponseError
    # Non-fatal: proceed without comments
  end

  # Fetch linked merge requests / related issues
  begin
    links = client.issue_links(project_path, issue_iid)
    if links.any?
      lines << "## Related issues"
      lines << ""
      links.each do |link|
        lines << "- ##{link.iid}: #{link.title} (#{link.state})"
      end
      lines << ""
    end
  rescue Gitlab::Error::ResponseError, NoMethodError
    # Non-fatal: some GitLab versions don't support this
  end

  lines.join("\n")
end

def clarification_answered?(client, project_path, issue_iid, requested_at)
  return true unless requested_at # No timestamp means we should retry

  notes = client.issue_notes(project_path, issue_iid, per_page: 100)
  # Check for non-system, non-autodev comments posted after the clarification request
  notes.any? do |note|
    !note.system &&
      note.created_at > requested_at &&
      !note.body.to_s.include?("**autodev**")
  end
rescue Gitlab::Error::ResponseError
  false
end

# == Shell helpers =============================================================

def run_cmd(cmd, chdir: nil, env: {})
  spawn_opts = {}
  spawn_opts[:chdir] = chdir if chdir
  out, err, status = Open3.capture3(env, *cmd, **spawn_opts)
  unless status.success?
    raise GitError, "Command failed: #{cmd.is_a?(Array) ? cmd.join(" ") : cmd}\nstdout: #{out[0, 500]}\nstderr: #{err[0, 500]}"
  end
  out.strip
end

def run_cmd_status(cmd, chdir: nil, env: {})
  spawn_opts = {}
  spawn_opts[:chdir] = chdir if chdir
  out, err, status = Open3.capture3(env, *cmd, **spawn_opts)
  [out.strip, err.strip, status.success?]
end

# == IssueProcessor ===========================================================

class IssueProcessor
  def initialize(client:, config:, project_config:, logger:, token:)
    @client         = client
    @config         = config
    @project_config = project_config
    @logger         = logger
    @token          = token
    @project_path   = project_config["path"]
    @gitlab_url     = config["gitlab_url"]
    @dc_stdout      = +""
    @dc_stderr      = +""
  end

  def process(issue)
    iid   = issue.iid
    title = issue.title

    log "Processing issue ##{iid}: #{title}"
    Database.update_issue(@project_path, iid, status: "cloning", started_at: Sequel.lit("datetime('now')"))

    # Verify issue is still open
    current = @client.issue(@project_path, iid)
    if current.state != "opened"
      log "Issue ##{iid} is no longer open (#{current.state}), skipping"
      Database.update_issue(@project_path, iid, status: "done", finished_at: Sequel.lit("datetime('now')"))
      return
    end

    notify_issue(iid, ":robot: **autodev** : traitement en cours...")

    # Check for partial progress from previous attempt
    existing = Database.find_issue(@project_path, iid)
    previous_branch = existing[:branch_name] if existing
    reuse_branch = previous_branch && branch_exists_on_remote?(previous_branch)
    skip_to_mr = false

    if reuse_branch
      log "Branch #{previous_branch} already exists on remote, checking for recovery..."
      if %w[creating_mr reviewing].include?(existing[:status]) || existing[:error_message]&.include?("creating_mr")
        skip_to_mr = true
        log "Recovering: skipping to MR creation"
      end
    end

    work_dir = "/tmp/autodev_#{@project_path.gsub("/", "_")}_#{iid}"
    begin
      if skip_to_mr
        # Re-clone just to get the work_dir for MR description extraction
        clone_repo(work_dir)
        run_cmd(["git", "checkout", previous_branch], chdir: work_dir)
        branch_name = previous_branch
      else
        # 1. Clone
        clone_repo(work_dir)

        # 2. Branch — reuse existing remote branch or create a new one
        if reuse_branch
          log "Reusing existing branch: #{previous_branch}"
          run_cmd(["git", "checkout", previous_branch], chdir: work_dir)
          branch_name = previous_branch
        else
          branch_name = create_branch(work_dir, iid, title)
        end
        Database.update_issue(@project_path, iid, branch_name: branch_name, status: "implementing")

        # 3. Fetch full issue context
        context = fetch_issue_context(@client, @project_path, iid, gitlab_url: @gitlab_url, token: @token, work_dir: work_dir)

        # 4. Check specification clarity
        if check_specification(work_dir, context, iid)
          # Spec needs clarification — abort processing
          return
        end

        # 5. Ensure CLAUDE.md exists
        ensure_claude_md(work_dir)

        # 6. Implement
        implement(work_dir, context, iid)
        Database.update_issue(@project_path, iid, status: "committing")

        # 7. Commit
        commit(work_dir)

        # 8. Verify changes were produced
        verify_changes(work_dir, branch_name)
        Database.update_issue(@project_path, iid, status: "pushing")

        # 8. Push
        push(work_dir, branch_name)
      end

      # 9. Create MR
      Database.update_issue(@project_path, iid, status: "creating_mr")
      mr = create_merge_request(work_dir, iid, branch_name, title)
      Database.update_issue(@project_path, iid, mr_iid: mr.iid, mr_url: mr.web_url, status: "reviewing")

      # 10. Labels (after MR to avoid bad state on failure)
      update_labels(iid)

      # 11. Review (non-fatal)
      run_review(mr.web_url)

      Database.update_issue(@project_path, iid,
        status: "done", finished_at: Sequel.lit("datetime('now')"),
        dc_stdout: @dc_stdout, dc_stderr: @dc_stderr
      )
      notify_issue(iid, ":white_check_mark: **autodev** : MR creee : #{mr.web_url}")
      log "Issue ##{iid} completed: #{mr.web_url}"

    rescue StandardError => e
      bt = e.backtrace&.first(10)&.join("\n  ")
      existing = Database.find_issue(@project_path, iid)
      retry_count = (existing ? existing[:retry_count] : 0) + 1
      max_retries = (@project_config["max_retries"] || @config["max_retries"] || 3).to_i
      backoff = (@project_config["retry_backoff"] || @config["retry_backoff"] || 30).to_i
      backoff_seconds = backoff * (2**(retry_count - 1))

      fields = {
        status: "error",
        error_message: "#{e.class}: #{e.message}\n  #{bt}",
        dc_stdout: @dc_stdout, dc_stderr: @dc_stderr,
        retry_count: retry_count,
        finished_at: Sequel.lit("datetime('now')")
      }

      if retry_count < max_retries
        fields[:next_retry_at] = Sequel.lit("datetime('now', '+#{backoff_seconds} seconds')")
        log_error "Issue ##{iid} failed (attempt #{retry_count}/#{max_retries}, retry in #{backoff_seconds}s): #{e.class}: #{e.message}"
      else
        log_error "Issue ##{iid} failed (attempt #{retry_count}/#{max_retries}, no more retries): #{e.class}: #{e.message}"
      end

      Database.update_issue(@project_path, iid, **fields)
      notify_issue(iid, ":x: **autodev** : echec — #{e.class}: #{e.message[0, 200]}")
      log_error "  #{bt}" if bt
    ensure
      # Cleanup temp directory
      FileUtils.rm_rf(work_dir) if work_dir && Dir.exist?(work_dir)
    end
  end

  private

  def clone_repo(work_dir)
    FileUtils.rm_rf(work_dir) if Dir.exist?(work_dir)

    uri = URI.parse(@gitlab_url)
    host_port = uri.port && ![80, 443].include?(uri.port) ? "#{uri.host}:#{uri.port}" : uri.host
    clone_url = "#{uri.scheme}://oauth2:#{@token}@#{host_port}/#{@project_path}.git"

    clone_depth = @project_config["clone_depth"] || 1
    sparse_paths = @project_config["sparse_checkout"]

    target = @project_config["target_branch"]

    cmd = ["git", "clone"]
    cmd += ["--depth", clone_depth.to_s] if clone_depth.positive?
    cmd += ["--branch", target] if target
    if sparse_paths.is_a?(Array) && sparse_paths.any?
      cmd += ["--filter=blob:none", "--sparse"]
    end
    cmd += [clone_url, work_dir]

    log "Cloning #{@project_path} (depth: #{clone_depth.positive? ? clone_depth : "full"})..."
    run_cmd(cmd)

    if sparse_paths.is_a?(Array) && sparse_paths.any?
      log "Setting up sparse checkout: #{sparse_paths.join(", ")}"
      run_cmd(["git", "sparse-checkout", "set"] + sparse_paths, chdir: work_dir)
    end
  end

  def create_branch(work_dir, iid, title)
    # target_branch is already checked out via --branch in clone_repo

    slug = I18n.transliterate(title)
                .downcase
                .gsub(/[^a-z0-9\s-]/, "")
                .gsub(/\s+/, "-")
                .gsub(/-+/, "-")
                .gsub(/^-|-$/, "")[0, 50]
    random = SecureRandom.hex(4)
    branch_name = "autodev/#{iid}-#{slug}-#{random}"

    run_cmd(["git", "checkout", "-b", branch_name], chdir: work_dir)
    log "Created branch: #{branch_name}"
    branch_name
  end

  def ensure_claude_md(work_dir)
    claude_md = File.join(work_dir, "CLAUDE.md")
    return if File.exist?(claude_md)

    log "No CLAUDE.md found, generating..."
    danger_claude_prompt(
      work_dir,
      "Analyse ce projet (structure, technologies, conventions, tests) et cree un fichier CLAUDE.md " \
      "a la racine qui documente ces informations pour guider les futurs developpements. " \
      "Sois concis et factuel."
    )
    danger_claude_commit(work_dir)
  end

  def check_specification(work_dir, context, iid)
    log "Checking specification clarity for ##{iid}..."

    prompt = <<~PROMPT
      Analyse le ticket GitLab suivant et determine si la specification est suffisamment precise
      pour etre implementee. Identifie les ambiguites, informations manquantes ou contradictions.

      #{context}

      ## Instructions de reponse

      Reponds UNIQUEMENT avec un objet JSON valide (sans bloc de code markdown), avec cette structure :
      {
        "clear": true/false,
        "issues": ["description du probleme 1", "description du probleme 2"]
      }

      - Si la specification est suffisamment claire pour etre implementee, reponds {"clear": true, "issues": []}
      - Si elle ne l'est pas, liste les problemes specifiques dans "issues"
      - Sois pragmatique : des details mineurs ne doivent pas bloquer l'implementation
      - Concentre-toi sur les ambiguites qui pourraient mener a une implementation incorrecte
    PROMPT

    out = danger_claude_prompt(work_dir, prompt)

    # Parse the JSON response
    json_match = out.match(/\{[^{}]*"clear"\s*:\s*(true|false)[^{}]*\}/m)
    unless json_match
      log "Could not parse spec check response, proceeding with implementation"
      return false
    end

    result = JSON.parse(json_match[0])

    if result["clear"]
      log "Specification is clear, proceeding"
      return false
    end

    issues_list = result["issues"] || []
    if issues_list.empty?
      log "Spec check returned unclear but no issues listed, proceeding"
      return false
    end

    # Post comment with ambiguities and mark as needs_clarification
    comment = <<~COMMENT
      :thinking: **autodev** : la specification necessite des precisions avant implementation.

      #{issues_list.map.with_index(1) { |issue, i| "#{i}. #{issue}" }.join("\n")}

      Merci de repondre a ces questions dans les commentaires. L'implementation reprendra automatiquement.
    COMMENT

    notify_issue(iid, comment.strip)
    Database.update_issue(@project_path, iid,
      status: "needs_clarification",
      clarification_requested_at: Sequel.lit("datetime('now')")
    )
    log "Issue ##{iid} needs clarification, #{issues_list.size} question(s) posted"
    true
  rescue JSON::ParserError
    log "Could not parse spec check JSON response, proceeding with implementation"
    false
  end

  def implement(work_dir, context, iid)
    extra = @project_config["extra_prompt"]
    prompt = <<~PROMPT
      Tu dois implementer le ticket GitLab suivant. Lis attentivement le contexte complet ci-dessous,
      puis implemente les changements necessaires dans le code.

      #{context}

      ## Instructions

      - Implemente TOUS les changements decrits dans l'issue.
      - Respecte les conventions du projet (voir CLAUDE.md si present).
      - Ajoute ou modifie les tests si necessaire.
      - Ne modifie que ce qui est necessaire pour resoudre l'issue.
      #{extra ? "\n## Instructions supplementaires du projet\n\n#{extra}" : ""}
    PROMPT

    log "Running implementation via danger-claude..."
    danger_claude_prompt(work_dir, prompt)
  end

  def commit(work_dir)
    log "Committing changes via danger-claude..."
    danger_claude_commit(work_dir)
  end

  def verify_changes(work_dir, branch_name)
    # Check if there are commits beyond the base
    target = @project_config["target_branch"] || default_branch(work_dir)
    out, _err, ok = run_cmd_status(
      ["git", "log", "#{target}..#{branch_name}", "--oneline"],
      chdir: work_dir
    )
    if !ok || out.strip.empty?
      raise ImplementationError, "No changes produced by implementation"
    end
  end

  def default_branch(work_dir)
    # Try to detect default branch from remote
    out, _err, ok = run_cmd_status(["git", "symbolic-ref", "refs/remotes/origin/HEAD", "--short"], chdir: work_dir)
    if ok && !out.empty?
      out.sub("origin/", "")
    else
      "main"
    end
  end

  def push(work_dir, branch_name)
    log "Pushing #{branch_name}..."
    _out, _err, ok = run_cmd_status(
      ["git", "push", "-u", "origin", branch_name],
      chdir: work_dir
    )
    unless ok
      # Retry with force-with-lease
      log "Push failed, retrying with --force-with-lease..."
      run_cmd(["git", "push", "--force-with-lease", "-u", "origin", branch_name], chdir: work_dir)
    end
  end

  def update_labels(iid)
    # Remove configured labels
    labels_to_remove = @project_config["labels_to_remove"] || []
    label_to_add     = @project_config["label_to_add"]

    begin
      issue = @client.issue(@project_path, iid)
      current_labels = issue.labels || []

      new_labels = current_labels - labels_to_remove
      new_labels << label_to_add if label_to_add && !new_labels.include?(label_to_add)

      @client.edit_issue(@project_path, iid, labels: new_labels.join(","))
      log "Labels updated: removed #{labels_to_remove & current_labels}, added #{label_to_add}"
    rescue Gitlab::Error::ResponseError => e
      log_error "Failed to update labels for ##{iid}: #{e.message}"
    end
  end

  def create_merge_request(work_dir, iid, branch_name, issue_title)
    target = @project_config["target_branch"] || default_branch(work_dir)

    # Get commit message for MR description
    commit_msg = run_cmd(["git", "log", "-1", "--format=%B"], chdir: work_dir)
    commit_subject = run_cmd(["git", "log", "-1", "--format=%s"], chdir: work_dir)

    mr_title = commit_subject
    mr_description = "#{commit_msg}\n\nFixes ##{iid}"

    # Check if MR already exists for this branch
    begin
      existing_mrs = @client.merge_requests(@project_path, source_branch: branch_name, state: "opened")
      if existing_mrs.any?
        mr = existing_mrs.first
        log "MR already exists: !#{mr.iid}"
        return mr
      end
    rescue Gitlab::Error::ResponseError
      # Continue to create
    end

    log "Creating MR: #{mr_title}"
    @client.create_merge_request(
      @project_path,
      mr_title,
      source_branch: branch_name,
      target_branch: target,
      description:   mr_description
    )
  end

  def run_review(mr_url)
    unless command_exists?("mr-review")
      log "mr-review not installed, skipping review"
      return
    end

    log "Waiting 15s for GitLab to compute diff_refs..."
    sleep 15
    log "Running mr-review on #{mr_url}..."
    _, err, status = Open3.capture3(CLEAN_ENV, "mr-review", "-H", mr_url)
    if status.success?
      log "Review completed successfully"
    else
      log_error "mr-review failed (non-fatal): #{err[0, 300]}"
    end
  rescue StandardError => e
    log_error "mr-review error (non-fatal): #{e.message}"
  end

  def danger_claude_prompt(work_dir, prompt)
    @logger.debug("danger-claude -p prompt:\n#{prompt}", project: @project_path)
    out, err, ok = run_with_timeout("danger-claude", ["-p", prompt], chdir: work_dir, label: "-p")
    unless ok
      raise ImplementationError, "danger-claude -p failed:\nstdout: #{out[0, 500]}\nstderr: #{err[0, 500]}"
    end
    out
  end

  def danger_claude_commit(work_dir)
    out, err, ok = run_with_timeout("danger-claude", ["-c"], chdir: work_dir, label: "-c")
    unless ok
      raise ImplementationError, "danger-claude -c failed:\nstdout: #{out[0, 500]}\nstderr: #{err[0, 500]}"
    end
    out
  end

  def run_with_timeout(cmd, args, chdir:, label: nil)
    timeout = (@project_config["dc_timeout"] || @config["dc_timeout"] || 1800).to_i
    tag = label ? "#{cmd} #{label}" : cmd

    stdout_r, stdout_w = IO.pipe
    stderr_r, stderr_w = IO.pipe

    pid = Process.spawn(CLEAN_ENV, cmd, *args, chdir: chdir, out: stdout_w, err: stderr_w)
    stdout_w.close
    stderr_w.close

    # Read output in threads to avoid pipe buffer deadlock
    out_thread = Thread.new { stdout_r.read }
    err_thread = Thread.new { stderr_r.read }

    deadline = Process.clock_gettime(Process::CLOCK_MONOTONIC) + timeout
    loop do
      remaining = deadline - Process.clock_gettime(Process::CLOCK_MONOTONIC)
      if remaining <= 0
        Process.kill("TERM", pid)
        sleep 5
        Process.kill("KILL", pid) rescue nil
        Process.wait(pid) rescue nil
        out = out_thread.value
        err = err_thread.value
        @dc_stdout << "=== #{tag} (TIMEOUT after #{timeout}s) ===\n#{out}\n"
        @dc_stderr << "=== #{tag} (TIMEOUT after #{timeout}s) ===\n#{err}\n"
        raise ImplementationError, "#{tag} timed out after #{timeout}s"
      end

      _pid, status = Process.wait2(pid, Process::WNOHANG)
      if status
        out = out_thread.value
        err = err_thread.value
        @dc_stdout << "=== #{tag} ===\n#{out}\n"
        @dc_stderr << "=== #{tag} ===\n#{err}\n"
        return [out, err, status.success?]
      end

      sleep 1
    end
  ensure
    stdout_r&.close
    stderr_r&.close
  end

  def notify_issue(iid, message)
    @client.create_issue_note(@project_path, iid, message)
  rescue Gitlab::Error::ResponseError => e
    log_error "Failed to post comment on ##{iid}: #{e.message}"
  end

  def branch_exists_on_remote?(branch_name)
    # Use GitLab API to check if branch exists
    @client.branch(@project_path, branch_name)
    true
  rescue Gitlab::Error::ResponseError
    false
  end

  def command_exists?(cmd)
    _, status = Open3.capture2e("which", cmd)
    status.success?
  end

  def log(msg)
    @logger.info(msg, project: @project_path)
  end

  def log_error(msg)
    @logger.error(msg, project: @project_path)
  end
end

# == MrFixer ==================================================================

class MrFixer
  def initialize(client:, config:, project_config:, logger:, token:)
    @client         = client
    @config         = config
    @project_config = project_config
    @logger         = logger
    @token          = token
    @project_path   = project_config["path"]
    @gitlab_url     = config["gitlab_url"]
    @dc_stdout      = +""
    @dc_stderr      = +""
  end

  def fix(issue_row)
    iid        = issue_row[:issue_iid]
    mr_iid     = issue_row[:mr_iid]
    branch     = issue_row[:branch_name]
    fix_round  = issue_row[:fix_round]

    log "Checking MR !#{mr_iid} for unresolved discussions (round #{fix_round + 1})..."

    # Verify the issue still has the trigger label
    trigger_label = @config["trigger_label"]
    begin
      gi = @client.issue(@project_path, iid)
      unless gi.labels&.include?(trigger_label)
        log "Issue ##{iid} no longer has '#{trigger_label}' label, skipping"
        return
      end
    rescue Gitlab::Error::ResponseError => e
      log_error "Cannot fetch issue ##{iid}: #{e.message}"
      return
    end

    # Fetch unresolved discussions
    discussions = fetch_unresolved_discussions(mr_iid)
    if discussions.empty?
      log "No unresolved discussions on MR !#{mr_iid}, moving to mr_fixed"
      Database.update_issue(@project_path, iid, status: "mr_fixed")
      return
    end

    log "Found #{discussions.size} unresolved discussion(s) on MR !#{mr_iid}"
    Database.update_issue(@project_path, iid, status: "mr_fixing")

    work_dir = "/tmp/autodev_mrfix_#{@project_path.gsub("/", "_")}_#{iid}"
    begin
      # Clone and checkout the branch
      clone_and_checkout(work_dir, branch)

      # Process each discussion: one danger-claude call + one commit per discussion
      discussions.each_with_index do |discussion, idx|
        thread_context = format_discussion(discussion)
        log "Fixing discussion #{idx + 1}/#{discussions.size}: #{discussion[:title]}"

        extra = @project_config["extra_prompt"]
        prompt = <<~PROMPT
          Tu dois corriger le code en reponse a un commentaire de review sur une Merge Request.

          ## Commentaire de review

          #{thread_context}

          ## Instructions

          - Lis attentivement le commentaire et le contexte du diff.
          - Corrige le code pour repondre au commentaire.
          - Respecte les conventions du projet (voir CLAUDE.md si present).
          - Ne modifie que ce qui est necessaire pour repondre au commentaire.
          - Ne touche pas aux autres parties du code.
          #{extra ? "\n## Instructions supplementaires du projet\n\n#{extra}" : ""}
        PROMPT

        danger_claude_prompt(work_dir, prompt)
        danger_claude_commit(work_dir)

        # Resolve the discussion
        resolve_discussion(mr_iid, discussion[:id])
      end

      # Verify there are new commits
      _out, _err, ok = run_cmd_status(["git", "log", "origin/#{branch}..HEAD", "--oneline"], chdir: work_dir)
      unless ok
        log "No new commits after fixing, skipping push"
        Database.update_issue(@project_path, iid, status: "mr_fixed", fix_round: fix_round + 1)
        return
      end

      # Push
      log "Pushing fixes to #{branch}..."
      _out, _err, push_ok = run_cmd_status(["git", "push", "origin", branch], chdir: work_dir)
      unless push_ok
        log "Push failed, retrying with --force-with-lease..."
        run_cmd(["git", "push", "--force-with-lease", "origin", branch], chdir: work_dir)
      end

      Database.update_issue(@project_path, iid,
        status: "mr_fixed",
        fix_round: fix_round + 1,
        dc_stdout: @dc_stdout,
        dc_stderr: @dc_stderr
      )
      notify_issue(iid, ":wrench: **autodev** : #{discussions.size} commentaire(s) de review corrige(s) sur #{issue_row[:mr_url]} (round #{fix_round + 1})")
      log "MR !#{mr_iid}: fixed #{discussions.size} discussion(s) (round #{fix_round + 1})"

    rescue StandardError => e
      bt = e.backtrace&.first(10)&.join("\n  ")
      Database.update_issue(@project_path, iid,
        status: "error",
        error_message: "MR fix error: #{e.class}: #{e.message}\n  #{bt}",
        dc_stdout: @dc_stdout, dc_stderr: @dc_stderr
      )
      notify_issue(iid, ":x: **autodev** : echec correction MR — #{e.class}: #{e.message[0, 200]}")
      log_error "MR fix failed: #{e.class}: #{e.message}"
      log_error "  #{bt}" if bt
    ensure
      FileUtils.rm_rf(work_dir) if work_dir && Dir.exist?(work_dir)
    end
  end

  private

  def clone_and_checkout(work_dir, branch)
    FileUtils.rm_rf(work_dir) if Dir.exist?(work_dir)

    uri = URI.parse(@gitlab_url)
    host_port = uri.port && ![80, 443].include?(uri.port) ? "#{uri.host}:#{uri.port}" : uri.host
    clone_url = "#{uri.scheme}://oauth2:#{@token}@#{host_port}/#{@project_path}.git"

    clone_depth = @project_config["clone_depth"] || 1
    cmd = ["git", "clone"]
    cmd += ["--depth", clone_depth.to_s] if clone_depth.positive?
    cmd += ["--branch", branch]
    cmd += [clone_url, work_dir]

    log "Cloning #{@project_path} (branch: #{branch})..."
    run_cmd(cmd)
  end

  def fetch_unresolved_discussions(mr_iid)
    discussions = @client.merge_request_discussions(@project_path, mr_iid)
    discussions.select { |d| d.notes&.any? && !resolved?(d) }.map do |d|
      first_note = d.notes.first
      {
        id:    d.id,
        title: first_note.body.to_s[0, 80],
        notes: d.notes
      }
    end
  rescue Gitlab::Error::ResponseError => e
    log_error "Failed to fetch MR discussions: #{e.message}"
    []
  end

  def resolved?(discussion)
    # A discussion is resolved if all resolvable notes are resolved
    resolvable_notes = discussion.notes.select { |n| n.respond_to?(:resolvable) && n.resolvable }
    return true if resolvable_notes.empty?
    resolvable_notes.all? { |n| n.respond_to?(:resolved) && n.resolved }
  end

  def format_discussion(discussion)
    lines = []
    discussion[:notes].each do |note|
      author = note.author&.name || "Unknown"
      lines << "### #{author} (#{note.created_at})"
      if note.respond_to?(:position) && note.position
        pos = note.position
        lines << "Fichier: `#{pos.respond_to?(:new_path) ? pos.new_path : pos["new_path"]}`" if pos
      end
      lines << note.body.to_s
      lines << ""
    end
    lines.join("\n")
  end

  def resolve_discussion(mr_iid, discussion_id)
    @client.resolve_merge_request_discussion(@project_path, mr_iid, discussion_id, resolved: true)
    log "Resolved discussion #{discussion_id}"
  rescue Gitlab::Error::ResponseError => e
    log_error "Failed to resolve discussion #{discussion_id}: #{e.message}"
  end

  def notify_issue(iid, message)
    @client.create_issue_note(@project_path, iid, message)
  rescue Gitlab::Error::ResponseError => e
    log_error "Failed to post comment on ##{iid}: #{e.message}"
  end

  def danger_claude_prompt(work_dir, prompt)
    @logger.debug("danger-claude -p prompt:\n#{prompt}", project: @project_path)
    out, err, ok = run_with_timeout("danger-claude", ["-p", prompt], chdir: work_dir, label: "-p")
    unless ok
      raise ImplementationError, "danger-claude -p failed:\nstdout: #{out[0, 500]}\nstderr: #{err[0, 500]}"
    end
    out
  end

  def danger_claude_commit(work_dir)
    out, err, ok = run_with_timeout("danger-claude", ["-c"], chdir: work_dir, label: "-c")
    unless ok
      raise ImplementationError, "danger-claude -c failed:\nstdout: #{out[0, 500]}\nstderr: #{err[0, 500]}"
    end
    out
  end

  def run_with_timeout(cmd, args, chdir:, label: nil)
    timeout = (@project_config["dc_timeout"] || @config["dc_timeout"] || 1800).to_i
    tag = label ? "#{cmd} #{label}" : cmd

    stdout_r, stdout_w = IO.pipe
    stderr_r, stderr_w = IO.pipe

    pid = Process.spawn(CLEAN_ENV, cmd, *args, chdir: chdir, out: stdout_w, err: stderr_w)
    stdout_w.close
    stderr_w.close

    out_thread = Thread.new { stdout_r.read }
    err_thread = Thread.new { stderr_r.read }

    deadline = Process.clock_gettime(Process::CLOCK_MONOTONIC) + timeout
    loop do
      remaining = deadline - Process.clock_gettime(Process::CLOCK_MONOTONIC)
      if remaining <= 0
        Process.kill("TERM", pid)
        sleep 5
        Process.kill("KILL", pid) rescue nil
        Process.wait(pid) rescue nil
        out = out_thread.value
        err = err_thread.value
        @dc_stdout << "=== #{tag} (TIMEOUT after #{timeout}s) ===\n#{out}\n"
        @dc_stderr << "=== #{tag} (TIMEOUT after #{timeout}s) ===\n#{err}\n"
        raise ImplementationError, "#{tag} timed out after #{timeout}s"
      end

      _pid, status = Process.wait2(pid, Process::WNOHANG)
      if status
        out = out_thread.value
        err = err_thread.value
        @dc_stdout << "=== #{tag} ===\n#{out}\n"
        @dc_stderr << "=== #{tag} ===\n#{err}\n"
        return [out, err, status.success?]
      end

      sleep 1
    end
  ensure
    stdout_r&.close
    stderr_r&.close
  end

  def log(msg)
    @logger.info(msg, project: @project_path)
  end

  def log_error(msg)
    @logger.error(msg, project: @project_path)
  end
end

# == PipelineMonitor ===========================================================

class PipelineMonitor
  def initialize(client:, config:, project_config:, logger:, token:)
    @client         = client
    @config         = config
    @project_config = project_config
    @logger         = logger
    @token          = token
    @project_path   = project_config["path"]
    @gitlab_url     = config["gitlab_url"]
    @dc_stdout      = +""
    @dc_stderr      = +""
  end

  def check(issue_row)
    iid    = issue_row[:issue_iid]
    mr_iid = issue_row[:mr_iid]

    log "Checking pipeline for MR !#{mr_iid} (issue ##{iid})..."

    # Fetch the MR to get head_pipeline
    mr = @client.merge_request(@project_path, mr_iid)
    pipeline = mr.head_pipeline

    unless pipeline
      log "No pipeline found for MR !#{mr_iid}, checking conversations..."
      handle_green(issue_row)
      return
    end

    status = pipeline.respond_to?(:status) ? pipeline.status : pipeline["status"]
    log "Pipeline ##{pipeline_id(pipeline)} status: #{status}"

    case status
    when "running", "pending", "created", "waiting_for_resource", "preparing", "scheduled"
      log "Pipeline still running for MR !#{mr_iid}, skipping"
      # Do nothing — recheck next poll
    when "success"
      handle_green(issue_row)
    when "failed"
      handle_red(issue_row, pipeline)
    when "canceled", "skipped"
      # Treat like a non-code failure
      log "Pipeline #{status} for MR !#{mr_iid}"
      Database.update_issue(@project_path, iid, status: "blocked")
      notify_issue(iid, ":warning: **autodev** : le pipeline de #{issue_row[:mr_url]} est #{status}. Intervention manuelle requise.")
      log "Issue ##{iid}: pipeline #{status} → blocked"
    else
      log "Unknown pipeline status '#{status}' for MR !#{mr_iid}, skipping"
    end
  rescue Gitlab::Error::ResponseError => e
    log_error "Failed to check pipeline for MR !#{mr_iid}: #{e.message}"
  rescue StandardError => e
    bt = e.backtrace&.first(5)&.join("\n  ")
    log_error "Pipeline check failed for issue ##{issue_row[:issue_iid]}: #{e.class}: #{e.message}"
    log_error "  #{bt}" if bt
  end

  private

  def handle_green(issue_row)
    iid    = issue_row[:issue_iid]
    mr_iid = issue_row[:mr_iid]

    # Pipeline green — check for unresolved conversations
    discussions = fetch_unresolved_discussions(mr_iid)
    if discussions.empty?
      Database.update_issue(@project_path, iid, status: "over")
      log "Issue ##{iid}: pipeline green, no open conversations → over"
    else
      max_fix_rounds = (@project_config["max_fix_rounds"] || @config["max_fix_rounds"]).to_i
      if issue_row[:fix_round] >= max_fix_rounds
        Database.update_issue(@project_path, iid, status: "over")
        log "Issue ##{iid}: pipeline green, #{discussions.size} conversation(s) but max fix rounds reached → over"
      else
        Database.update_issue(@project_path, iid, status: "mr_fixing")
        log "Issue ##{iid}: pipeline green, #{discussions.size} unresolved conversation(s) → mr_fixing"
      end
    end
  end

  def handle_red(issue_row, pipeline)
    iid    = issue_row[:issue_iid]
    mr_iid = issue_row[:mr_iid]
    retrigger_count = issue_row[:pipeline_retrigger_count] || 0

    if retrigger_count < 1
      # Retrigger once
      log "Pipeline failed for MR !#{mr_iid}, retriggering (attempt #{retrigger_count + 1})..."
      begin
        @client.retry_pipeline(@project_path, pipeline_id(pipeline))
        Database.update_issue(@project_path, iid, pipeline_retrigger_count: retrigger_count + 1)
        log "Pipeline retriggered for MR !#{mr_iid}"
      rescue Gitlab::Error::ResponseError => e
        log_error "Failed to retrigger pipeline: #{e.message}"
        # Proceed to evaluation since retrigger failed
        evaluate_failure(issue_row, pipeline)
      end
    else
      # Already retriggered — evaluate the failure
      evaluate_failure(issue_row, pipeline)
    end
  end

  def evaluate_failure(issue_row, pipeline)
    iid       = issue_row[:issue_iid]
    fix_round = issue_row[:fix_round]

    # Fetch failed jobs and their logs
    failed_jobs = fetch_failed_jobs(pipeline)
    if failed_jobs.empty?
      log "No failed jobs found for pipeline ##{pipeline_id(pipeline)}, marking as blocked"
      Database.update_issue(@project_path, iid, status: "blocked")
      notify_issue(iid, ":warning: **autodev** : le pipeline de #{issue_row[:mr_url]} a echoue mais aucun job en echec n'a ete trouve. Intervention manuelle requise.")
      return
    end

    # Build context with job logs for Claude evaluation
    job_context = build_job_context(failed_jobs)

    # Clone once — used for both evaluation and potential fix
    work_dir = "/tmp/autodev_pipeline_#{@project_path.gsub("/", "_")}_#{iid}"
    begin
      clone_and_checkout(work_dir, issue_row[:branch_name])

      # Step 1: Evaluate if the failure is code-related
      eval_result = evaluate_code_related(work_dir, job_context)

      unless eval_result
        # Could not parse evaluation — default to blocked
        log "Could not parse pipeline evaluation response, marking as blocked"
        Database.update_issue(@project_path, iid, status: "blocked")
        notify_issue(iid, ":warning: **autodev** : le pipeline de #{issue_row[:mr_url]} a echoue et l'evaluation automatique n'a pas abouti. Intervention manuelle requise.")
        return
      end

      explanation = eval_result["explanation"] || "Aucune explication fournie"

      unless eval_result["code_related"]
        Database.update_issue(@project_path, iid, status: "blocked")
        notify_issue(iid, ":warning: **autodev** : le pipeline de #{issue_row[:mr_url]} echoue pour une raison hors code. Intervention manuelle requise.\n\n> #{explanation}")
        log "Issue ##{iid}: non-code pipeline failure → blocked (#{explanation})"
        return
      end

      # Code-related failure — check if we can still fix
      max_fix_rounds = (@project_config["max_fix_rounds"] || @config["max_fix_rounds"]).to_i
      if fix_round >= max_fix_rounds
        Database.update_issue(@project_path, iid, status: "blocked")
        notify_issue(iid, ":warning: **autodev** : le pipeline de #{issue_row[:mr_url]} echoue a cause du code mais le nombre maximum de rounds de fix est atteint. Intervention manuelle requise.\n\n> #{explanation}")
        log "Issue ##{iid}: code-related pipeline failure but max fix rounds reached → blocked"
        return
      end

      # Step 2: Fix the code based on pipeline failure logs
      log "Issue ##{iid}: code-related pipeline failure, fixing... (#{explanation})"
      Database.update_issue(@project_path, iid, status: "mr_pipeline_fixing")

      fix_pipeline_failure(work_dir, job_context, issue_row)

    rescue StandardError => e
      bt = e.backtrace&.first(10)&.join("\n  ")
      log_error "Pipeline evaluation/fix failed: #{e.class}: #{e.message}"
      log_error "  #{bt}" if bt
      Database.update_issue(@project_path, iid,
        status: "error",
        error_message: "Pipeline fix error: #{e.class}: #{e.message}\n  #{bt}",
        dc_stdout: @dc_stdout, dc_stderr: @dc_stderr
      )
      notify_issue(iid, ":x: **autodev** : echec de la correction du pipeline — #{e.class}: #{e.message[0, 200]}")
    ensure
      FileUtils.rm_rf(work_dir) if work_dir && Dir.exist?(work_dir)
    end
  end

  def build_job_context(failed_jobs)
    failed_jobs.map do |job|
      name = job.respond_to?(:name) ? job.name : job["name"]
      stage = job.respond_to?(:stage) ? job.stage : job["stage"]
      trace = fetch_job_trace(job)
      "### Job: #{name} (stage: #{stage})\n\n```\n#{trace}\n```"
    end.join("\n\n")
  end

  def evaluate_code_related(work_dir, job_context)
    prompt = <<~PROMPT
      Tu dois analyser un echec de pipeline CI/CD sur une Merge Request et determiner s'il est lie au code ou non.

      ## Jobs en echec

      #{job_context}

      ## Instructions de reponse

      Reponds UNIQUEMENT avec un objet JSON valide (sans bloc de code markdown), avec cette structure :
      {
        "code_related": true/false,
        "explanation": "explication courte de la cause"
      }

      - `code_related: true` si l'echec vient du code (test qui echoue, erreur de compilation, lint, etc.)
      - `code_related: false` si l'echec vient de l'infrastructure (timeout reseau, service indisponible, quota, permission, image Docker introuvable, etc.)
      - Sois pragmatique dans ton evaluation
    PROMPT

    out = danger_claude_prompt(work_dir, prompt)
    json_match = out.match(/\{[^{}]*"code_related"\s*:\s*(true|false)[^{}]*\}/m)
    return nil unless json_match

    JSON.parse(json_match[0])
  rescue JSON::ParserError
    nil
  end

  def fix_pipeline_failure(work_dir, job_context, issue_row)
    iid       = issue_row[:issue_iid]
    branch    = issue_row[:branch_name]
    fix_round = issue_row[:fix_round]

    extra = @project_config["extra_prompt"]
    prompt = <<~PROMPT
      Tu dois corriger le code pour resoudre un echec de pipeline CI/CD.

      ## Jobs en echec

      #{job_context}

      ## Instructions

      - Analyse les logs des jobs en echec ci-dessus.
      - Corrige le code source pour que ces jobs passent au vert.
      - Respecte les conventions du projet (voir CLAUDE.md si present).
      - Ne modifie que ce qui est necessaire pour corriger les erreurs de pipeline.
      - Ne touche pas aux fichiers de configuration CI/CD sauf si c'est la cause directe de l'echec.
      #{extra ? "\n## Instructions supplementaires du projet\n\n#{extra}" : ""}
    PROMPT

    danger_claude_prompt(work_dir, prompt)
    danger_claude_commit(work_dir)

    # Verify there are new commits
    _out, _err, ok = run_cmd_status(["git", "log", "origin/#{branch}..HEAD", "--oneline"], chdir: work_dir)
    unless ok
      log "No new commits after pipeline fix, skipping push"
      Database.update_issue(@project_path, iid, status: "mr_fixed", fix_round: fix_round + 1,
        dc_stdout: @dc_stdout, dc_stderr: @dc_stderr)
      return
    end

    # Push
    log "Pushing pipeline fix to #{branch}..."
    _out, _err, push_ok = run_cmd_status(["git", "push", "origin", branch], chdir: work_dir)
    unless push_ok
      log "Push failed, retrying with --force-with-lease..."
      run_cmd(["git", "push", "--force-with-lease", "origin", branch], chdir: work_dir)
    end

    Database.update_issue(@project_path, iid,
      status: "mr_fixed",
      fix_round: fix_round + 1,
      dc_stdout: @dc_stdout,
      dc_stderr: @dc_stderr
    )
    notify_issue(iid, ":wrench: **autodev** : correction du pipeline appliquee sur #{issue_row[:mr_url]} (round #{fix_round + 1})")
    log "Issue ##{iid}: pipeline fix pushed (round #{fix_round + 1})"
  end

  def danger_claude_commit(work_dir)
    out, err, ok = run_with_timeout("danger-claude", ["-c"], chdir: work_dir, label: "-c (pipeline fix)")
    unless ok
      raise ImplementationError, "danger-claude -c failed:\nstdout: #{out[0, 500]}\nstderr: #{err[0, 500]}"
    end
    out
  end

  def fetch_failed_jobs(pipeline)
    pid = pipeline_id(pipeline)
    jobs = @client.pipeline_jobs(@project_path, pid, per_page: 100)
    jobs.select do |j|
      status = j.respond_to?(:status) ? j.status : j["status"]
      status == "failed"
    end
  rescue Gitlab::Error::ResponseError => e
    log_error "Failed to fetch pipeline jobs: #{e.message}"
    []
  end

  def fetch_job_trace(job)
    jid = job.respond_to?(:id) ? job.id : job["id"]
    trace = @client.job_trace(@project_path, jid)
    # Limit trace to last 3000 chars to stay within prompt limits
    trace = trace.to_s
    trace.length > 3000 ? trace[-3000..] : trace
  rescue Gitlab::Error::ResponseError => e
    log_error "Failed to fetch job trace: #{e.message}"
    "(trace unavailable: #{e.message})"
  end

  def fetch_unresolved_discussions(mr_iid)
    discussions = @client.merge_request_discussions(@project_path, mr_iid)
    discussions.select { |d| d.notes&.any? && !resolved?(d) }
  rescue Gitlab::Error::ResponseError => e
    log_error "Failed to fetch MR discussions: #{e.message}"
    []
  end

  def resolved?(discussion)
    resolvable_notes = discussion.notes.select { |n| n.respond_to?(:resolvable) && n.resolvable }
    return true if resolvable_notes.empty?
    resolvable_notes.all? { |n| n.respond_to?(:resolved) && n.resolved }
  end

  def clone_and_checkout(work_dir, branch)
    FileUtils.rm_rf(work_dir) if Dir.exist?(work_dir)

    uri = URI.parse(@gitlab_url)
    host_port = uri.port && ![80, 443].include?(uri.port) ? "#{uri.host}:#{uri.port}" : uri.host
    clone_url = "#{uri.scheme}://oauth2:#{@token}@#{host_port}/#{@project_path}.git"

    clone_depth = @project_config["clone_depth"] || 1
    cmd = ["git", "clone"]
    cmd += ["--depth", clone_depth.to_s] if clone_depth.positive?
    cmd += ["--branch", branch]
    cmd += [clone_url, work_dir]

    run_cmd(cmd)
  end

  def danger_claude_prompt(work_dir, prompt)
    @logger.debug("danger-claude -p prompt:\n#{prompt}", project: @project_path)
    out, err, ok = run_with_timeout("danger-claude", ["-p", prompt], chdir: work_dir, label: "-p (pipeline eval)")
    unless ok
      raise ImplementationError, "danger-claude -p failed:\nstdout: #{out[0, 500]}\nstderr: #{err[0, 500]}"
    end
    out
  end

  def run_with_timeout(cmd, args, chdir:, label: nil)
    timeout = (@project_config["dc_timeout"] || @config["dc_timeout"] || 1800).to_i
    tag = label ? "#{cmd} #{label}" : cmd

    stdout_r, stdout_w = IO.pipe
    stderr_r, stderr_w = IO.pipe

    pid = Process.spawn(CLEAN_ENV, cmd, *args, chdir: chdir, out: stdout_w, err: stderr_w)
    stdout_w.close
    stderr_w.close

    out_thread = Thread.new { stdout_r.read }
    err_thread = Thread.new { stderr_r.read }

    deadline = Process.clock_gettime(Process::CLOCK_MONOTONIC) + timeout
    loop do
      remaining = deadline - Process.clock_gettime(Process::CLOCK_MONOTONIC)
      if remaining <= 0
        Process.kill("TERM", pid)
        sleep 5
        Process.kill("KILL", pid) rescue nil
        Process.wait(pid) rescue nil
        out = out_thread.value
        err = err_thread.value
        @dc_stdout << "=== #{tag} (TIMEOUT after #{timeout}s) ===\n#{out}\n"
        @dc_stderr << "=== #{tag} (TIMEOUT after #{timeout}s) ===\n#{err}\n"
        raise ImplementationError, "#{tag} timed out after #{timeout}s"
      end

      _pid, status = Process.wait2(pid, Process::WNOHANG)
      if status
        out = out_thread.value
        err = err_thread.value
        @dc_stdout << "=== #{tag} ===\n#{out}\n"
        @dc_stderr << "=== #{tag} ===\n#{err}\n"
        return [out, err, status.success?]
      end

      sleep 1
    end
  ensure
    stdout_r&.close
    stderr_r&.close
  end

  def pipeline_id(pipeline)
    pipeline.respond_to?(:id) ? pipeline.id : pipeline["id"]
  end

  def notify_issue(iid, message)
    @client.create_issue_note(@project_path, iid, message)
  rescue Gitlab::Error::ResponseError => e
    log_error "Failed to post comment on ##{iid}: #{e.message}"
  end

  def log(msg)
    @logger.info(msg, project: @project_path)
  end

  def log_error(msg)
    @logger.error(msg, project: @project_path)
  end
end

# == WorkerPool ================================================================

class WorkerPool
  def initialize(size:, logger:)
    @size    = size
    @queue   = Queue.new
    @logger  = logger
    @threads = []
    @running = true
  end

  def start
    @threads = @size.times.map do |i|
      Thread.new do
        Thread.current.name = "worker-#{i}"
        while @running
          begin
            job = @queue.pop(true)
            job.call
          rescue ThreadError
            # Queue empty, wait briefly
            sleep 0.5
          rescue StandardError => e
            @logger.error("[worker-#{i}] Unhandled error: #{e.class}: #{e.message}")
          end
        end
      end
    end
  end

  def enqueue(&block)
    @queue.push(block)
  end

  def shutdown(timeout: 30)
    @running = false
    # Push sentinel values to unblock waiting threads
    @size.times { @queue.push(-> {}) }
    @threads.each { |t| t.join(timeout) }
  end

  def busy?
    !@queue.empty?
  end
end

# == Main ======================================================================

def main
  pastel = Pastel.new
  logger = AppLogger.new(pastel: pastel)

  logger.info("+=== autodev ================================================+")

  # 1. Parse args + load config
  config = parse_args(ARGV)

  # 2. Configure logger
  logger.configure(log_dir: config["log_dir"], level: config["log_level"])

  # 3. Validate — offer to create template config if missing
  config_path = config["_config_path"] || Config::CONFIG_PATH

  unless File.exist?(config_path)
    logger.warn("No config file found at #{config_path}")
    print pastel.bold("  Create a template config to edit? [Y/n] ")
    answer = $stdin.gets&.strip&.downcase
    if answer.nil? || answer.empty? || answer == "y"
      FileUtils.mkdir_p(File.dirname(config_path))
      File.write(config_path, Config::TEMPLATE)
      logger.info("Created #{config_path}")
      logger.info("Edit this file with your GitLab URL, token and projects, then re-run autodev.")
      exit 0
    else
      raise ConfigError, "No config file at #{config_path}. Create one manually or re-run to generate a template."
    end
  end

  unless config["projects"].is_a?(Array) && config["projects"].any?
    raise ConfigError, "No projects configured in #{config_path}. Add at least one entry under 'projects:'."
  end

  unless config["gitlab_url"] && config["gitlab_url"] != "https://gitlab.example.com"
    raise ConfigError, "Set a valid gitlab_url in #{config_path}"
  end

  # Check danger-claude is available
  _, dc_status = Open3.capture2e("which", "danger-claude")
  raise ConfigError, "danger-claude is not installed or not on PATH" unless dc_status.success?

  # Check mr-review (warning only)
  _, mr_status = Open3.capture2e("which", "mr-review")
  unless mr_status.success?
    logger.warn("mr-review not installed, review step will be skipped")
  end

  # 4. Connect SQLite + migrate
  token = config["gitlab_token"]
  client = build_gitlab_client(config["gitlab_url"], token)

  if Database.connect(config["database_url"])
    logger.debug("Database connected")
  else
    raise ConfigError, "Database connection required for autodev"
  end

  # Reset errored issues for retry
  reset_count = Database.reset_errors_to_pending!(max_retries: config["max_retries"])
  logger.warn("Reset #{reset_count} errored issue(s) to pending") if reset_count && reset_count > 0

  # 5. Start WorkerPool
  pool = WorkerPool.new(size: config["max_workers"], logger: logger)
  pool.start
  logger.debug("Worker pool started (#{config["max_workers"]} workers)")

  # 6. Trap signals
  shutdown_requested = false
  %w[INT TERM].each do |sig|
    Signal.trap(sig) do
      shutdown_requested = true
    end
  end

  trigger_label = config["trigger_label"]

  # 7. Poll loop
  loop do
    break if shutdown_requested

    config["projects"].each do |project_config|
      break if shutdown_requested

      project_path = project_config["path"]
      logger.debug("Polling #{project_path} for label '#{trigger_label}'...", project: project_path)

      begin
        issues = fetch_trigger_issues(client, project_path, trigger_label)

        issues.each do |issue|
          break if shutdown_requested

          # Skip if already tracked (unless it was reset to pending)
          existing = Database.find_issue(project_path, issue.iid)
          if existing
            if existing[:status] == "needs_clarification"
              # Check if new comments were posted since clarification was requested
              if clarification_answered?(client, project_path, issue.iid, existing[:clarification_requested_at])
                logger.info("Issue ##{issue.iid}: clarification received, re-queuing", project: project_path)
                Database.update_issue(project_path, issue.iid,
                  status: "pending", clarification_requested_at: nil, error_message: nil)
              else
                next
              end
            elsif existing[:status] != "pending"
              next
            end
          end

          # Skip if max retries exceeded
          max_retries = (project_config["max_retries"] || config["max_retries"]).to_i
          if Database.exceeded_max_retries?(project_path, issue.iid, max_retries)
            logger.debug("Issue ##{issue.iid} exceeded max retries (#{max_retries}), skipping", project: project_path)
            next
          end

          if config["dry_run"]
            logger.info("[dry-run] Would process issue ##{issue.iid}: #{issue.title}", project: project_path)
            next
          end

          # Insert if new
          unless existing
            Database.insert_issue(
              project_path: project_path,
              issue_iid:    issue.iid,
              issue_title:  issue.title
            )
          end

          # Build a per-worker client (thread safety)
          worker_client = build_gitlab_client(config["gitlab_url"], token)

          processor = IssueProcessor.new(
            client:         worker_client,
            config:         config,
            project_config: project_config,
            logger:         logger,
            token:          token
          )

          pool.enqueue { processor.process(issue) }
          logger.info("Enqueued issue ##{issue.iid}: #{issue.title}", project: project_path)
        end
      rescue AutodevError => e
        logger.error("Error polling #{project_path}: #{e.message}", project: project_path)
      end

      # -- Transition done/mr_fixed → mr_pipeline_running --
      next if config["dry_run"]
      begin
        max_fix_rounds = (project_config["max_fix_rounds"] || config["max_fix_rounds"]).to_i
        Database.transition_to_pipeline_running!(project_path, max_fix_rounds)
      rescue StandardError => e
        logger.error("Error transitioning to pipeline_running for #{project_path}: #{e.message}", project: project_path)
      end

      # -- Pipeline monitoring poll --
      begin
        pipeline_issues = Database.issues_for_pipeline_monitoring(project_path)
        pipeline_issues.each do |issue_row|
          break if shutdown_requested

          worker_client = build_gitlab_client(config["gitlab_url"], token)
          monitor = PipelineMonitor.new(
            client:         worker_client,
            config:         config,
            project_config: project_config,
            logger:         logger,
            token:          token
          )

          pool.enqueue { monitor.check(issue_row) }
          logger.info("Enqueued pipeline check for issue ##{issue_row[:issue_iid]} (MR !#{issue_row[:mr_iid]})", project: project_path)
        end
      rescue StandardError => e
        logger.error("Error polling pipeline monitoring for #{project_path}: #{e.message}", project: project_path)
      end

      # -- MR comment fixing poll --
      begin
        max_fix_rounds = (project_config["max_fix_rounds"] || config["max_fix_rounds"]).to_i
        fixable = Database.issues_for_mr_fixing(project_path, max_fix_rounds)

        fixable.each do |issue_row|
          break if shutdown_requested

          worker_client = build_gitlab_client(config["gitlab_url"], token)
          fixer = MrFixer.new(
            client:         worker_client,
            config:         config,
            project_config: project_config,
            logger:         logger,
            token:          token
          )

          pool.enqueue { fixer.fix(issue_row) }
          logger.info("Enqueued MR fix for issue ##{issue_row[:issue_iid]} (round #{issue_row[:fix_round] + 1})", project: project_path)
        end
      rescue StandardError => e
        logger.error("Error polling MR fixes for #{project_path}: #{e.message}", project: project_path)
      end
    end

    break if config["once"]

    # Sleep in 1s increments for reactive shutdown
    config["poll_interval"].times do
      break if shutdown_requested
      sleep 1
    end
  end

  # 8. Graceful shutdown
  logger.info("Shutting down workers...")
  pool.shutdown
  logger.info("autodev stopped.")

rescue ConfigError => e
  logger&.error("Config error: #{e.message}") || (warn "Config error: #{e.message}")
  exit 1

rescue Interrupt
  logger&.warn("Interrupted.") || (warn "Interrupted.")
  exit 130

rescue StandardError => e
  logger&.error("Unexpected error: #{e.class}: #{e.message}") || (warn "Unexpected error: #{e.class}: #{e.message}")
  logger&.error(e.backtrace&.first(5)&.join("\n  ")) if e.backtrace
  exit 1

ensure
  logger&.close
  Database.disconnect
end

main
