#!/usr/bin/env ruby
# frozen_string_literal: true

# =============================================================================
# autodev
#
# Automated implementation of GitLab issues labelled with a trigger label.
# Polls configured projects, clones the repo, implements via danger-claude,
# commits, pushes, manages labels, creates a Merge Request, and optionally
# runs mr-review in headless mode.
#
# Usage:
#   autodev                                  # Poll with default config
#   autodev --once                           # Single poll cycle then exit
#   autodev --status                         # Show dashboard of tracked issues
#   autodev --errors                         # Show details for all errored/blocked issues
#   autodev --errors 15712                   # Show details for a specific errored/blocked issue
#   autodev --reset                          # Reset all errored issues to pending
#   autodev --reset 15712                    # Reset a specific errored issue to pending
#   autodev -c ~/.autodev/custom.yml --once  # Custom config, single cycle
#
# Configuration (priority: defaults < config.yml < env vars < CLI flags):
#   ~/.autodev/config.yml    Central config file
#   GITLAB_API_TOKEN         Personal Access Token with api scope
# =============================================================================

require 'bundler/inline'

gemfile(true) do
  source 'https://rubygems.org'
  gem 'gitlab',  '~> 5.0'
  gem 'sequel',  '~> 5.0'
  gem 'sqlite3', '~> 2.0'
  gem 'pastel',  '~> 0.8'
  gem 'i18n',    '~> 1.0'
  gem 'aasm',    '~> 5.5'
  gem 'logger'
end

require 'fileutils'
require 'json'
require 'open3'
require 'optparse'
require 'shellwords'
require 'net/http'
require 'uri'
require 'yaml'
require 'i18n'
require 'securerandom'

# Configure I18n transliteration (no locale files needed, just the transliterator)
I18n.available_locales = [:en]
I18n.default_locale = :en

require_relative '../lib/autodev'

# == Argument parsing ==========================================================

def parse_args(argv)
  cli_overrides = {}
  build_option_parser(cli_overrides).parse(argv)
  Config.load(cli_overrides)
end

def build_option_parser(cli_overrides)
  OptionParser.new do |opts|
    opts.banner = 'Usage: autodev [options]'
    define_connection_options(opts, cli_overrides)
    define_mode_options(opts, cli_overrides)
    define_query_options(opts, cli_overrides)
    define_info_options(opts)
  end
end

def define_connection_options(opts, overrides)
  opts.on('-c', '--config PATH', 'Config file (default: ~/.autodev/config.yml)') { |v| overrides['config_path'] = v }
  opts.on('-d', '--database-url URL', 'SQLite database URL') { |v| overrides['database_url'] = v }
  opts.on('-t', '--token TOKEN', 'GitLab API token') { |v| overrides['gitlab_token'] = v }
  opts.on('-n', '--max-workers N', Integer, 'Concurrent workers (default: 3)') { |v| overrides['max_workers'] = v }
  opts.on('-i', '--interval SECONDS', Integer, 'Poll interval in seconds') { |v| overrides['poll_interval'] = v }
end

def define_mode_options(opts, overrides)
  opts.on('--once', 'Single poll cycle then exit') { overrides['once'] = true }
  opts.on('--dry-run', 'Poll and show what would be processed, no side effects') do
    overrides['dry_run'] = true
    overrides['once'] = true
  end
end

def define_query_options(opts, overrides)
  define_status_options(opts, overrides)
  define_reset_and_errors_options(opts, overrides)
end

def define_status_options(opts, overrides)
  opts.on('--status', 'Show dashboard of active issues and exit') { overrides['status'] = true }
  opts.on('--all', 'Include completed (over) issues in --status') { overrides['status_all'] = true }
end

def define_reset_and_errors_options(opts, overrides)
  opts.on('--reset [IID]', Integer, 'Reset error issues to pending (optionally by issue IID)') do |iid|
    overrides['reset'] = true
    overrides['reset_iid'] = iid
  end
  opts.on('--errors [IID]', Integer,
          'Show details for errored and blocked issues (optionally for a specific issue IID)') do |iid|
    overrides['errors'] = true
    overrides['errors_iid'] = iid
  end
end

def define_info_options(opts)
  opts.on('-v', '--version', 'Show version and exit') do
    puts "autodev #{Autodev::VERSION}"
    exit 0
  end
  opts.on('-h', '--help', 'Show this help') do
    puts opts
    exit 0
  end
end

# == Early commands ============================================================

def handle_early_commands(config, pastel)
  run_early_command(config, pastel, 'status') { Dashboard.show(config) }
  run_early_command(config, pastel, 'errors') { Dashboard.show_errors(config) }
  run_early_command(config, pastel, 'reset') { Dashboard.reset(config, pastel) }
end

def run_early_command(config, _pastel, key)
  return unless config[key]

  yield
  exit 0
end

# == Setup =====================================================================

def offer_template_config(config_path, logger, pastel)
  return if File.exist?(config_path)

  logger.warn("No config file found at #{config_path}")
  print pastel.bold('  Create a template config to edit? [Y/n] ')
  answer = $stdin.gets&.strip&.downcase
  unless answer.nil? || answer.empty? || answer == 'y'
    raise ConfigError, "No config file at #{config_path}. Create one manually or re-run to generate a template."
  end

  write_template_config(config_path, logger)
end

def write_template_config(config_path, logger)
  FileUtils.mkdir_p(File.dirname(config_path))
  File.write(config_path, Config::TEMPLATE)
  logger.info("Created #{config_path}")
  logger.info('Edit this file with your GitLab URL, token and projects, then re-run autodev.')
  exit 0
end

def validate_config(config, config_path, logger)
  validate_config_entries(config, config_path)
  Config.validate!(config)
  check_dependencies(logger)
end

def validate_config_entries(config, config_path)
  unless config['projects'].is_a?(Array) && config['projects'].any?
    raise ConfigError, "No projects configured in #{config_path}. Add at least one entry under 'projects:'."
  end

  return if config['gitlab_url'] && config['gitlab_url'] != 'https://gitlab.example.com'

  raise ConfigError, "Set a valid gitlab_url in #{config_path}"
end

def check_dependencies(logger)
  _, dc_status = Open3.capture2e('which', 'danger-claude')
  raise ConfigError, 'danger-claude is not installed or not on PATH' unless dc_status.success?

  _, mr_status = Open3.capture2e('which', 'mr-review')
  logger.warn('mr-review not installed, review step will be skipped') unless mr_status.success?
end

def setup_database(config, logger)
  raise ConfigError, 'Database connection required for autodev' unless Database.connect(config['database_url'])

  Database.build_model!
  logger.debug('Database connected, Issue model initialized')
  reset_count = Database.recover_on_startup!(max_retries: config['max_retries'])
  logger.warn("Recovered #{reset_count} issue(s) on startup") if reset_count.positive?
end

# == Main ======================================================================

def setup_chrome_devtools(config, logger)
  return unless config['chrome_devtools']

  ChromeLauncher.ensure_running!(logger: logger)
  ChromeDevtoolsInjector.inject_mcp_config!(logger: logger)
end

def bootstrap(config, logger, pastel)
  logger.info('+=== autodev ================================================+')
  logger.configure(log_dir: config['log_dir'], level: config['log_level'])

  config_path = config['_config_path'] || Config::CONFIG_PATH
  offer_template_config(config_path, logger, pastel)
  validate_config(config, config_path, logger)
  setup_database(config, logger)
  setup_chrome_devtools(config, logger)
end

def log_or_warn(logger, msg)
  logger&.error(msg) || (warn msg)
end

def handle_fatal(error, logger)
  case error
  when ConfigError then log_or_warn(logger, "Config error: #{error.message}")
  when Interrupt   then logger&.warn('Interrupted.') || (warn 'Interrupted.')
  else
    log_or_warn(logger, "Unexpected error: #{error.class}: #{error.message}")
    logger&.error(error.backtrace.first(5).join("\n  ")) if error.backtrace
  end
  error.is_a?(Interrupt) ? exit(130) : exit(1)
end

def cleanup(logger)
  logger&.close
  Database.disconnect
end

def main
  pastel = Pastel.new
  logger = AppLogger.new(pastel: pastel)
  config = parse_args(ARGV)
  handle_early_commands(config, pastel)
  bootstrap(config, logger, pastel)
  Poller.new(config: config, logger: logger, pastel: pastel).run
rescue StandardError, Interrupt => e
  handle_fatal(e, logger)
ensure
  cleanup(logger)
end

main
